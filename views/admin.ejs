    function qbFormatNumber(num, format) {
      if (format === 'indian') {
        return qbFormatIndianNumber(num);
      }
      return num.toLocaleString('en-US');
    }

    function qbFormatIndianNumber(num) {
      // Indian numbering system: 1,23,456.78
      const str = num.toString();
      const parts = str.split('.');
      let integer = parts[0];
      const decimal = parts[1] || '';
      
      // Get the last 3 digits
      const lastThree = integer.substring(integer.length - 3);
      const otherNumbers = integer.substring(0, integer.length - 3);
      
      let formatted = '';
      if (otherNumbers !== '') {
        // Add comma every 2 digits from right
        const reversed = otherNumbers.split('').reverse().join('');
        const withCommas = reversed.match(/.{1,2}/g).join(',');
        formatted = withCommas.split('').reverse().join('') + ',' + lastThree;
      } else {
        formatted = lastThree;
      }
      
      return decimal ? formatted + '.' + decimal : formatted;
    }

    function qbFormatDate(date, format) {
      const d = new Date(date);
      const day = String(d.getDate()).padStart(2, '0');
      const month = String(d.getMonth() + 1).padStart(2, '0');
      const year = d.getFullYear();
      
      switch(format) {
        case 'dd-mm-yyyy':
          return `${day}-${month}-${year}`;
        case 'mm-dd-yyyy':
          return `${month}-${day}-${year}`;
        case 'yyyy-mm-dd':
          return `${year}-${month}-${day}`;
        default:
          return d.toLocaleDateString();
      }
    }

