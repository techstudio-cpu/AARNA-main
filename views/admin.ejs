      if (qbDiscountCodes[code]) {
        qbData.activeDiscount = code;
        qbUpdatePricingDisplay();
        showToast('Discount applied: ' + qbDiscountCodes[code].label, 'success');
      } else {
        qbData.activeDiscount = null;
        qbUpdatePricingDisplay();
        showToast('Invalid discount code', 'error');
