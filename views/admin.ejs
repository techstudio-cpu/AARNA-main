    function qbInitSignaturePad() {
      const canvas = document.getElementById('qbSignatureCanvas');
      if (!canvas) return;
      
      qbSignatureCtx = canvas.getContext('2d');
      qbSignatureCtx.strokeStyle = '#0f172a';
      qbSignatureCtx.lineWidth = 2;
      qbSignatureCtx.lineCap = 'round';
      qbSignatureCtx.lineJoin = 'round';
      
      // Clear any previous event listeners
      canvas.removeEventListener('mousedown', qbStartDrawing);
      canvas.removeEventListener('mousemove', qbDraw);
      canvas.removeEventListener('mouseup', qbStopDrawing);
      canvas.removeEventListener('mouseleave', qbStopDrawing);
      canvas.removeEventListener('touchstart', qbHandleTouch);
      canvas.removeEventListener('touchmove', qbHandleTouch);
      canvas.removeEventListener('touchend', qbStopDrawing);
      
      // Add event listeners
      canvas.addEventListener('mousedown', qbStartDrawing);
      canvas.addEventListener('mousemove', qbDraw);
      canvas.addEventListener('mouseup', qbStopDrawing);
      canvas.addEventListener('mouseleave', qbStopDrawing);
      canvas.addEventListener('touchstart', qbHandleTouch, { passive: false });
      canvas.addEventListener('touchmove', qbHandleTouch, { passive: false });
      canvas.addEventListener('touchend', qbStopDrawing);
    }

    function qbGetCanvasPos(e, canvas) {
      const rect = canvas.getBoundingClientRect();
      return {
        x: (e.clientX || e.touches[0].clientX) - rect.left,
        y: (e.clientY || e.touches[0].clientY) - rect.top
      };
    }

    function qbStartDrawing(e) {
      qbIsDrawing = true;
      const canvas = document.getElementById('qbSignatureCanvas');
      const pos = qbGetCanvasPos(e, canvas);
      qbSignatureCtx.beginPath();
      qbSignatureCtx.moveTo(pos.x, pos.y);
    }

    function qbDraw(e) {
      if (!qbIsDrawing) return;
      const canvas = document.getElementById('qbSignatureCanvas');
      const pos = qbGetCanvasPos(e, canvas);
      qbSignatureCtx.lineTo(pos.x, pos.y);
      qbSignatureCtx.stroke();
    }

    function qbStopDrawing() {
      qbIsDrawing = false;
    }

    function qbHandleTouch(e) {
      e.preventDefault();
      const touch = e.touches[0];
      const mouseEvent = new MouseEvent(e.type === 'touchstart' ? 'mousedown' : 'mousemove', {
        clientX: touch.clientX,
        clientY: touch.clientY
      });
      if (e.type === 'touchstart') {
        qbStartDrawing(mouseEvent);
      } else {
        qbDraw(mouseEvent);
      }
    }

    function qbClearSignature() {
      const canvas = document.getElementById('qbSignatureCanvas');
      if (!canvas) return;
      qbSignatureCtx.fillStyle = 'white';
      qbSignatureCtx.fillRect(0, 0, canvas.width, canvas.height);
      qbData.signature = null;
