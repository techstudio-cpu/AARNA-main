                <button onclick="deleteUser('${u.id}', '${u.displayName}')" style="padding: 6px 12px; border: 1px solid #FECACA; background: #FEF2F2; border-radius: 6px; cursor: pointer; font-size: 12px; color: #DC2626;" title="Delete">
                  🗑️
                </button>
              ` : '<span style="font-size: 11px; color: var(--text-muted); font-style: italic;">You</span>'}
            </div>
          </div>
        `).join('');
      } catch (e) {
        document.getElementById('usersList').innerHTML = '<p style="color: var(--danger); text-align: center; padding: 20px;">Failed to load users</p>';
      }
    }

