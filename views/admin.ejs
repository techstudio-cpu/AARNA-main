    // ─── PDF Generation ───
    async function qbGeneratePDF() {
      const btn = document.getElementById('qbPdfBtn');
      btn.disabled = true;
      btn.innerHTML = '<span class="qb-spinner"></span> Generating...';

      try {
        qbAutoBuild();
        // Wait for images to load
        await new Promise(r => setTimeout(r, 500));

        const container = document.getElementById('qbPdfContainer');
        const pages = container.querySelectorAll('.qb-page');
        const { jsPDF } = window.jspdf;
        const pdf = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });

        for (let i = 0; i < pages.length; i++) {
          const canvas = await html2canvas(pages[i], {
            scale: 2,
            useCORS: true,
            allowTaint: true,
            backgroundColor: '#ffffff',
            logging: false,
            width: pages[i].offsetWidth,
            height: pages[i].offsetHeight
          });
          const imgData = canvas.toDataURL('image/jpeg', 0.95);
          if (i > 0) pdf.addPage();
          pdf.addImage(imgData, 'JPEG', 0, 0, 210, 297);
        }

        const filename = 'Quotation_' + qbData.customerName.replace(/\s+/g, '_') + '_' + new Date().toISOString().split('T')[0] + '.pdf';
        pdf.save(filename);
      } catch (err) {
        console.error('PDF generation failed:', err);
        alert('Failed to generate PDF. Please try again.');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<span>📄</span> Download PDF';
      }
    }

    // ─── Template System ───
    let qbCurrentTemplateId = null;

    // Load templates list on init
    async function qbLoadTemplatesList() {
      try {
        const response = await fetch('/api/qb/templates');
        const data = await response.json();
        if (data.success) {
          const customGroup = document.getElementById('qbCustomTemplatesGroup');
          const customTemplates = data.templates.filter(t => !t.is_preset);
          
          if (customTemplates.length === 0) {
            customGroup.innerHTML = '<option value="" disabled>No custom templates yet</option>';
          } else {
            customGroup.innerHTML = customTemplates.map(t => 
              `<option value="${t.template_id}">${t.name}</option>`
            ).join('');
          }
        }
      } catch (err) {
        console.error('Failed to load templates:', err);
      }
    }

    // Load and apply a template
    async function qbLoadTemplate(templateId) {
      if (!templateId) return;
      
      // Check if it's a preset template
      const presetTemplates = {
        'tmpl-residential-std': { projectType: 'Residential On-Grid', capacity: 5, payback: 4.5, theme: 'forest', coverStyle: 'centered' },
        'tmpl-commercial-std': { projectType: 'Commercial On-Grid', capacity: 25, payback: 3.8, theme: 'ocean', coverStyle: 'modern-card' },
        'tmpl-industrial-std': { projectType: 'Industrial On-Grid', capacity: 100, payback: 3.2, theme: 'royal', coverStyle: 'left-aligned' },
        'tmpl-offgrid-std': { projectType: 'Residential Off-Grid', capacity: 3, payback: 5.5, theme: 'sunset', coverStyle: 'minimal' }
      };

      if (presetTemplates[templateId]) {
        const preset = presetTemplates[templateId];
        qbData.projectType = preset.projectType;
        qbData.capacityKwp = preset.capacity;
        qbData.paybackPeriod = preset.payback;
        qbData.theme = preset.theme;
        qbData.coverStyle = preset.coverStyle;
        
        // Update UI controls
        document.getElementById('qbProjectType').value = preset.projectType;
        document.getElementById('qbCapacity').value = preset.capacity;
        document.getElementById('qbPayback').value = preset.payback;
        document.getElementById('qbCoverStyle').value = preset.coverStyle;
        
        // Apply theme
        qbSelectTheme(preset.theme);
        
        // Load components from server
        try {
          const response = await fetch(`/api/qb/templates/${templateId}`);
          const data = await response.json();
          if (data.success && data.template.default_components) {
            qbData.components = data.template.default_components;
            qbRenderComponentsList();
          }
        } catch (err) {
          console.error('Failed to load preset components:', err);
        }
        
        qbCurrentTemplateId = templateId;
        document.getElementById('qbDeleteTemplateBtn').style.display = 'none';
      } else {
        // Custom template - load from server
        try {
          const response = await fetch(`/api/qb/templates/${templateId}`);
          const data = await response.json();
          if (data.success) {
            const template = data.template;
            
            // Apply template data
            if (template.default_project_type) qbData.projectType = template.default_project_type;
            if (template.default_capacity) qbData.capacityKwp = template.default_capacity;
            if (template.default_payback_period) qbData.paybackPeriod = template.default_payback_period;
            if (template.default_theme) qbData.theme = template.default_theme;
            if (template.default_cover_style) qbData.coverStyle = template.default_cover_style;
            if (template.default_service_layout) qbData.serviceLayout = template.default_service_layout;
            if (template.default_spacing) qbData.spacing = template.default_spacing;
            if (template.default_header_style) qbData.headerStyle = template.default_header_style;
            if (template.default_components) qbData.components = template.default_components;
            if (template.template_data) {
              // Apply saved design settings
              Object.assign(qbData, template.template_data);
            }
            
            // Update all UI controls
            qbUpdateUIFromData();
            qbRenderComponentsList();
            qbSelectTheme(qbData.theme);
            qbRenderPreview();
            
            qbCurrentTemplateId = templateId;
            document.getElementById('qbDeleteTemplateBtn').style.display = 'inline-block';
          }
        } catch (err) {
          console.error('Failed to load template:', err);
          alert('Failed to load template');
        }
      }
      
      qbAutoBuild();
    }

    // Update all UI controls from qbData (simplified)
    function qbUpdateUIFromData() {
      const el = (id) => document.getElementById(id);
      if (el('qbProjectType')) el('qbProjectType').value = qbData.projectType;
      if (el('qbCapacity')) el('qbCapacity').value = qbData.capacityKwp;
      if (el('qbMonthlyBill')) el('qbMonthlyBill').value = qbData.averageMonthlyBill;
      if (el('qbCustomerName')) el('qbCustomerName').value = qbData.customerName;
      if (el('qbLocation')) el('qbLocation').value = qbData.location;
      // Update auto summary
      const setText = (id, text) => { const e = document.getElementById(id); if (e) e.textContent = text; };
      setText('qbAutoArea', qbData.availableArea.toLocaleString() + ' sq.ft');
      setText('qbAutoGen', qbData.totalKwhPerYear.toLocaleString() + ' kWh');
      setText('qbAutoSubsidy', '₹' + qbData.subsidy.toLocaleString());
      setText('qbAutoPayback', qbData.paybackPeriod + ' yrs');
      setText('qbAutoTotal', '₹' + qbData.totalCost.toLocaleString());
    }

    // Show/Hide Save Template Modal
    function qbShowSaveTemplateModal() {
      document.getElementById('saveTemplateModal').style.display = 'flex';
      document.getElementById('qbTemplateName').value = '';
      document.getElementById('qbTemplateDescription').value = '';
      document.getElementById('qbTemplateCategory').value = 'custom';
    }

    function qbHideSaveTemplateModal() {
      document.getElementById('saveTemplateModal').style.display = 'none';
    }

    // Save current quotation as template
    async function qbSaveTemplate() {
      const name = document.getElementById('qbTemplateName').value.trim();
      const category = document.getElementById('qbTemplateCategory').value;
      const description = document.getElementById('qbTemplateDescription').value.trim();
      
      if (!name) {
        alert('Please enter a template name');
        return;
      }
      
      const templateData = {
        name: name,
        description: description,
        category: category,
        template_data: {
          theme: qbData.theme,
          useCustomColors: qbData.useCustomColors,
          customColors: qbData.customColors,
          coverStyle: qbData.coverStyle,
          serviceLayout: qbData.serviceLayout,
          spacing: qbData.spacing,
          headerStyle: qbData.headerStyle,
          showPages: qbData.showPages,
          showElements: qbData.showElements,
          showPageNumbers: qbData.showPageNumbers,
          bgPattern: qbData.bgPattern,
          pageBorder: qbData.pageBorder,
          waveStyle: qbData.waveStyle,
          iconStyle: qbData.iconStyle,
          fontFamily: qbData.fontFamily,
          logoPosition: qbData.logoPosition,
          customFooter: qbData.customFooter
        },
        default_components: qbData.components,
        default_theme: qbData.theme,
        default_cover_style: qbData.coverStyle,
        default_service_layout: qbData.serviceLayout,
        default_spacing: qbData.spacing,
        default_header_style: qbData.headerStyle,
        default_project_type: qbData.projectType,
        default_capacity: qbData.capacityKwp,
        default_payback_period: qbData.paybackPeriod
      };
      
      try {
        const response = await fetch('/api/qb/templates', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(templateData)
        });
        
        const data = await response.json();
        if (data.success) {
          alert('Template saved successfully!');
          qbHideSaveTemplateModal();
          qbLoadTemplatesList(); // Refresh list
        } else {
          alert('Failed to save template: ' + data.error);
        }
      } catch (err) {
        console.error('Failed to save template:', err);
        alert('Failed to save template');
      }
    }

    // Delete current custom template
    async function qbDeleteCurrentTemplate() {
      if (!qbCurrentTemplateId || qbCurrentTemplateId.startsWith('tmpl-') && ['tmpl-residential-std', 'tmpl-commercial-std', 'tmpl-industrial-std', 'tmpl-offgrid-std'].includes(qbCurrentTemplateId)) {
        alert('Cannot delete preset templates');
        return;
      }
      
      if (!confirm('Are you sure you want to delete this template?')) {
        return;
      }
      
      try {
        const response = await fetch(`/api/qb/templates/${qbCurrentTemplateId}`, {
          method: 'DELETE'
        });
        
        const data = await response.json();
        if (data.success) {
          alert('Template deleted successfully!');
          qbCurrentTemplateId = null;
          document.getElementById('qbTemplateSelect').value = '';
          document.getElementById('qbDeleteTemplateBtn').style.display = 'none';
          qbLoadTemplatesList(); // Refresh list
        } else {
          alert('Failed to delete template: ' + data.error);
        }
      } catch (err) {
        console.error('Failed to delete template:', err);
        alert('Failed to delete template');
      }
    }

    // Load templates on page load
    document.addEventListener('DOMContentLoaded', function() {
      qbLoadTemplatesList();
    });

    // Close modal on overlay click
    document.getElementById('saveTemplateModal').addEventListener('click', function(e) {
      if (e.target === this) qbHideSaveTemplateModal();
    });
  </script>
</body>
</html>
