    // Signature Pad
    let qbSignaturePad = null;
    let qbSignatureCtx = null;
    let qbIsDrawing = false;

    function qbToggleSignature(enabled) {
      document.getElementById('qbSignaturePad').style.display = enabled ? 'block' : 'none';
      
      if (enabled) {
