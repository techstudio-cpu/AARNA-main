    function qbCalculateComponentTotals() {
      let baseCost = 0;
      let totalWithMarkup = 0;
      let optionalCount = 0;
      
      qbData.components.forEach(c => {
        const price = c.unitPrice || 0;
        const markup = c.markup || 0;
        baseCost += price;
        totalWithMarkup += Math.round(price * (1 + markup / 100));
        if (c.isOptional) optionalCount++;
      });
      
      return { baseCost, totalWithMarkup, optionalCount };
    }

