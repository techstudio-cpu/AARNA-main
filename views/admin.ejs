                      <option value="unreliable" style="color: #1e293b;">Unreliable/Frequent outages</option>
                      <option value="nogrid" style="color: #1e293b;">No Grid (remote area)</option>
                    </select>
                  </div>
                  <div class="qb-field">
                    <label class="qb-label" style="color: rgba(255,255,255,0.85);">Need Battery Backup?</label>
                    <select class="qb-input" id="qbBackupNeed" onchange="qbRecommendSystem()" style="background: rgba(255,255,255,0.15); color: white; border-color: rgba(255,255,255,0.2);">
                      <option value="no" style="color: #1e293b;">No — Grid is sufficient</option>
                      <option value="yes" style="color: #1e293b;">Yes — Need power at night/outages</option>
                    </select>
                  </div>
                  <div id="qbAiRecommendation" style="background: rgba(255,255,255,0.15); padding: 12px; border-radius: 10px; margin-top: 8px; text-align: center;">
                    <p style="font-size: 10px; text-transform: uppercase; letter-spacing: 1px; opacity: 0.8; margin-bottom: 4px;">Recommended</p>
                    <p style="font-size: 16px; font-weight: 800; margin: 0;" id="qbAiRecText">On-Grid Solar</p>
                    <p style="font-size: 11px; opacity: 0.85; margin-top: 4px; line-height: 1.4;" id="qbAiRecReason">Best for areas with reliable grid and net metering benefits.</p>
                    <button onclick="qbFetchAIRecommendation()" id="qbAiBtn" style="margin-top:10px;background:rgba(255,255,255,0.2);color:white;border:1px solid rgba(255,255,255,0.3);border-radius:8px;padding:6px 14px;font-size:11px;font-weight:700;cursor:pointer;letter-spacing:0.5px;">
                      ✨ Get Aarna AI Recommendation
                    </button>
                  </div>
                </div>

                <!-- Auto-calculated Summary -->
                <div class="qb-form-section" style="background: var(--secondary); border-radius: 12px;">
