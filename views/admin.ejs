        return;
      }
      
      try {
        const response = await fetch(`/api/qb/quotations/${quotationId}/export/word`);
        
        if (response.ok) {
          const blob = await response.blob();
          const url = window.URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = `quotation-${qbData.customerName.replace(/\s+/g, '-')}.docx`;
          document.body.appendChild(a);
          a.click();
          window.URL.revokeObjectURL(url);
          document.body.removeChild(a);
          showToast('Word document downloaded', 'success');
        } else {
          showToast('Failed to export Word document', 'error');
        }
      } catch (err) {
        console.error('Error exporting Word:', err);
