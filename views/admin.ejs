                      <option value="Commercial On-Grid">Commercial On-Grid</option>
                      <option value="Commercial Hybrid">Commercial Hybrid</option>
                      <option value="Industrial On-Grid">Industrial On-Grid</option>
                    </select>
                  </div>
                  <div class="qb-field">
