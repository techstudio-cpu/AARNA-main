    function qbUpdatePaymentScheduleDisplay(total) {
      const container = document.getElementById('qbPaymentBreakdown');
      const schedule = qbData.paymentSchedule || '50-50';
      
      const stages = {
        'single': [{ name: 'On Delivery', percent: 100 }],
        '50-50': [{ name: 'Advance Payment', percent: 50 }, { name: 'On Completion', percent: 50 }],
        '3-stage': [{ name: 'Booking (Advance)', percent: 30 }, { name: 'Material Delivery', percent: 40 }, { name: 'Installation Complete', percent: 30 }],
        '4-stage': [{ name: 'Booking', percent: 25 }, { name: 'Material Delivery', percent: 25 }, { name: '50% Installation', percent: 25 }, { name: 'Final Handover', percent: 25 }],
        'emi': [{ name: 'Down Payment', percent: 20 }, { name: 'EMI (12 Months)', percent: 80 }]
      };
      
      const currentStages = stages[schedule] || stages['50-50'];
      
      container.innerHTML = currentStages.map(stage => {
        const amount = Math.round(total * stage.percent / 100);
        return `
          <div class="qb-payment-stage">
            <span>${stage.name} (${stage.percent}%)</span>
            <span class="qb-payment-amount">₹${amount.toLocaleString()}</span>
          </div>
        `;
      }).join('');
    }

