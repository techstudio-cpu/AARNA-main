    function refreshData() { location.reload(); }

    function exportAllLeads() {
      const rows = Array.from(document.querySelectorAll('.lead-row')).filter(r => r.style.display !== 'none');
      if (!rows.length) return alert('No leads to export');
      
      const headers = ['Name', 'Phone', 'Email', 'Location', 'Status', 'Priority', 'Source', 'Created'];
      const data = rows.map(row => {
        const cells = row.querySelectorAll('td');
        return [
          cells[0]?.querySelector('h4')?.textContent || '',
          cells[1]?.querySelector('a')?.textContent || '',
          cells[1]?.querySelector('div:last-child')?.textContent || '',
          cells[0]?.querySelector('p')?.textContent || '',
          cells[2]?.textContent?.trim() || '',
          cells[3]?.textContent?.trim() || '',
          cells[4]?.textContent?.trim() || '',
          cells[5]?.textContent?.trim() || ''
        ].map(v => `"${(v || '').replace(/"/g, '""')}"`).join(',');
      });
      
      const csv = [headers.join(','), ...data].join('\n');
      const blob = new Blob([csv], { type: 'text/csv' });
      const link = document.createElement('a');
      link.href = URL.createObjectURL(blob);
      link.download = `leads-${new Date().toISOString().split('T')[0]}.csv`;
      link.click();
    }

    // ─── Super Admin Functions ─────────────────────────────────────────
    async function confirmDeleteLead(leadId, leadName) {
      if (!isSuperAdmin) return alert('Only Super Admin can delete leads');
      if (!confirm(`Are you sure you want to permanently delete the lead "${leadName}"?\n\nThis action cannot be undone.`)) return;
      
      try {
        const res = await fetch('/api/leads/' + leadId, { method: 'DELETE' });
        if (res.ok) {
          closeModal();
          location.reload();
        } else {
          const data = await res.json();
          alert('Failed to delete lead: ' + (data.error || 'Unknown error'));
        }
      } catch (e) {
        alert('Error deleting lead: ' + e.message);
      }
    }

    // Bulk selection mode
    let bulkSelectMode = false;
    let selectedLeads = new Set();

    function toggleBulkSelect() {
      bulkSelectMode = !bulkSelectMode;
      selectedLeads.clear();
      const btn = document.getElementById('bulkSelectBtn');
      const delBtn = document.getElementById('bulkDeleteBtn');
      const statusBtn = document.getElementById('bulkStatusBtn');
      
      if (bulkSelectMode) {
        btn.textContent = '✖ Cancel';
        btn.style.background = '#FEE2E2';
        btn.style.color = '#DC2626';
        btn.style.borderColor = '#FECACA';
        delBtn.style.display = 'inline-block';
        statusBtn.style.display = 'inline-block';
        
        // Add checkboxes to each row
        document.querySelectorAll('.lead-row').forEach(row => {
          const id = row.dataset.id;
          const firstTd = row.querySelector('td');
          if (!firstTd.querySelector('.bulk-cb')) {
            const cb = document.createElement('input');
            cb.type = 'checkbox';
            cb.className = 'bulk-cb';
            cb.style.cssText = 'margin-right: 8px; width: 16px; height: 16px; cursor: pointer; vertical-align: middle;';
            cb.onchange = function() {
              if (this.checked) selectedLeads.add(id);
              else selectedLeads.delete(id);
              document.getElementById('selectedCount').textContent = selectedLeads.size;
            };
            firstTd.insertBefore(cb, firstTd.firstChild);
          }
        });
      } else {
        btn.textContent = '☑️ Select';
        btn.style.background = 'white';
        btn.style.color = '#92400E';
        btn.style.borderColor = '#D97706';
        delBtn.style.display = 'none';
        statusBtn.style.display = 'none';
        document.querySelectorAll('.bulk-cb').forEach(cb => cb.remove());
      }
      updateSelectedCount();
    }

    function updateSelectedCount() {
      document.getElementById('selectedCount').textContent = selectedLeads.size;
    }

    async function bulkDeleteSelected() {
      if (selectedLeads.size === 0) return alert('No leads selected');
      if (!confirm(`Are you sure you want to permanently delete ${selectedLeads.size} lead(s)?\n\nThis action cannot be undone.`)) return;
      
      try {
        const res = await fetch('/api/leads/bulk-delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ids: Array.from(selectedLeads) })
        });
        const data = await res.json();
        if (res.ok) {
          alert(`Successfully deleted ${data.deleted} lead(s)`);
          location.reload();
        } else {
          alert('Failed: ' + (data.error || 'Unknown error'));
        }
      } catch (e) {
        alert('Error: ' + e.message);
      }
    }

    async function bulkStatusSelected() {
      if (selectedLeads.size === 0) return alert('No leads selected');
      const status = prompt('Enter new status for selected leads:\n(new, contacted, qualified, proposal, negotiation, converted, lost)');
      if (!status) return;
      
      const validStatuses = ['new', 'contacted', 'qualified', 'proposal', 'negotiation', 'converted', 'lost'];
      if (!validStatuses.includes(status.toLowerCase())) return alert('Invalid status. Choose from: ' + validStatuses.join(', '));
      
      try {
        const res = await fetch('/api/leads/bulk-update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ids: Array.from(selectedLeads), field: 'status', value: status.toLowerCase() })
        });
        const data = await res.json();
        if (res.ok) {
          alert(`Successfully updated ${data.updated} lead(s)`);
          location.reload();
        } else {
          alert('Failed: ' + (data.error || 'Unknown error'));
        }
      } catch (e) {
        alert('Error: ' + e.message);
      }
    }

