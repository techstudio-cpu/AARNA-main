    async function qbConvertToInvoice() {
      const quotationId = qbCurrentQuotationId;
      if (!quotationId) {
        showToast('Please save the quotation first', 'error');
        return;
      }
      
      // Confirm conversion
      if (!confirm('Convert this quotation to an invoice? This will mark the quote as accepted.')) {
        return;
      }
      
      try {
        // Update approval status to approved
        await qbUpdateApprovalStatus('approved', 'Converted to invoice');
        
        // Log invoice creation activity
        await fetch('/api/clients/activities', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            client_id: qbSelectedClient ? qbSelectedClient.id : null,
            activity_type: 'invoice_created',
            description: `Invoice generated from quotation ${quotationId}`,
            quotation_id: quotationId,
            metadata: { 
              invoice_number: `INV-${Date.now().toString(36).toUpperCase()}`,
              amount: qbData.totalCost || 0
            }
          })
        });
        
        // Update workflow status
        qbUpdateWorkflowStatus('invoiced');
        
        showToast('🧾 Invoice created successfully', 'success');
      } catch (err) {
        console.error('Error converting to invoice:', err);
        showToast('Failed to create invoice', 'error');
      }
    }

    // Workflow Status Update
    function qbUpdateWorkflowStatus(status) {
      const workflowItems = document.querySelectorAll('.qb-workflow-item');
      const statuses = ['created', 'approval', 'sent', 'decision'];
      const currentIndex = statuses.indexOf(status);
      
      workflowItems.forEach((item, index) => {
        item.classList.remove('completed', 'active', 'pending');
        
        if (index < currentIndex) {
          item.classList.add('completed');
          item.querySelector('.qb-workflow-icon').textContent = '✓';
        } else if (index === currentIndex) {
          item.classList.add('active');
          item.querySelector('.qb-workflow-icon').textContent = '●';
        } else {
          item.classList.add('pending');
          item.querySelector('.qb-workflow-icon').textContent = '○';
        }
      });
    }

