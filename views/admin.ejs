  <!-- Session Management Modal (super_admin only) -->
  <div id="sessionsModal" class="modal">
    <div class="modal-content" style="max-width: 800px;">
      <div class="modal-header">
        <h2>Active Sessions</h2>
        <button class="modal-close" onclick="closeSessionsModal()">&times;</button>
      </div>
      <div class="modal-body">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
          <p style="font-size: 13px; color: var(--text-muted); margin: 0;">Monitor and manage user sessions</p>
          <button onclick="loadSessions()" style="padding: 8px 16px; background: var(--primary); color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 13px;">Refresh</button>
        </div>

        <div id="sessionsList" style="max-height: 400px; overflow-y: auto;">
          <p style="color: var(--text-muted); text-align: center; padding: 20px;">Loading sessions...</p>
        </div>
      </div>
    </div>
  </div>

  <!-- System Info Modal (super_admin only) -->
  <div id="systemInfoModal" class="modal">
    <div class="modal-content" style="max-width: 600px;">
      <div class="modal-header">
        <h2>System Information</h2>
        <button class="modal-close" onclick="document.getElementById('systemInfoModal').classList.remove('active')">&times;</button>
      </div>
      <div class="modal-body">
        <div id="systemInfoContent" style="display: grid; gap: 16px;">
          <p style="color: var(--text-muted); text-align: center; padding: 20px;">Loading system info...</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    const userRole = '<%= userRole %>';
    const userId = '<%= userId %>';
    const canEdit = (userRole === 'super_admin' || userRole === 'manager');

    // Pagination State
    let currentPage = 1;
    const pageSize = 25;
    let totalLeads = <%= pagination.total %>;
    let currentLeads = [];

    // Load leads with pagination
    async function loadLeads(page = 1, filters = {}) {
      const offset = (page - 1) * pageSize;
      const queryParams = new URLSearchParams({
        limit: pageSize,
        offset: offset,
        ...filters
      });

      try {
        const res = await fetch('/api/leads?' + queryParams.toString());
        if (!res.ok) {
          const errData = await res.json().catch(() => ({}));
          throw new Error(`HTTP ${res.status}: ${errData.error || res.statusText}`);
        }
        const data = await res.json();

        currentLeads = data.data;
        totalLeads = data.pagination?.total || 0;
        currentPage = page;

        renderLeadsTable(currentLeads);
        updatePaginationControls();
      } catch (e) {
        console.error('Failed to load leads:', e);
        document.getElementById('leadsTable').innerHTML = `
          <tr><td colspan="7" style="text-align: center; padding: 40px;">
            <div style="color: var(--danger); font-weight: 600; margin-bottom: 8px;">Failed to load leads</div>
            <div style="color: var(--text-muted); font-size: 12px; margin-bottom: 12px;">${e.message}</div>
            <button onclick="loadLeads(1)" style="background: var(--primary); color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer;">Retry</button>
          </td></tr>
        `;
      }
    }

    // Render leads table
    function renderLeadsTable(leads) {
      const tbody = document.getElementById('leadsTable');

      if (!leads || leads.length === 0) {
        tbody.innerHTML = `
          <tr><td colspan="7" style="text-align: center; padding: 40px; color: var(--text-muted);">
            No leads found
          </td></tr>
        `;
        return;
      }

      tbody.innerHTML = leads.map(contact => {
        const searchData = `${contact.name} ${contact.phone} ${contact.email || ''} ${contact.location || ''}`.toLowerCase();
        const followUpDate = contact.follow_up_date ? new Date(contact.follow_up_date) : null;
        const isOverdue = followUpDate && followUpDate <= new Date();

        return `
          <tr class="lead-row" data-id="${contact.id}" data-status="${contact.status || 'new'}" data-priority="${contact.priority || 'medium'}" data-search="${searchData}">
            <td>
              <div class="lead-cell">
                <div class="lead-avatar">${contact.name.charAt(0).toUpperCase()}</div>
                <div class="lead-info">
                  <h4>${contact.name}</h4>
                  <p>${contact.location || 'No location'}</p>
                </div>
              </div>
            </td>
            <td>
              <div><a href="tel:${contact.phone}" style="color: var(--primary); font-weight: 500;">${contact.phone}</a></div>
              <div style="font-size: 12px; color: var(--text-muted);">${contact.email || '-'}</div>
            </td>
            <td><span class="badge badge-${contact.status || 'new'}">${(contact.status || 'new').charAt(0).toUpperCase() + (contact.status || 'new').slice(1)}</span></td>
            <td><span class="badge badge-${contact.priority || 'medium'}">${(contact.priority || 'medium').charAt(0).toUpperCase() + (contact.priority || 'medium').slice(1)}</span></td>
            <td style="color: var(--text-muted); font-size: 13px;">${contact.source || 'website'}</td>
            <td>
              ${followUpDate ?
                `<span style="font-size: 13px; ${isOverdue ? 'color: var(--danger); font-weight: 500;' : 'color: var(--text-muted);'}">
                  ${followUpDate.toLocaleDateString('en-IN')}
                </span>` :
                '<span style="color: var(--text-muted); font-size: 13px;">-</span>'
              }
            </td>
            <td>
              <div class="action-btns">
                <button class="action-btn" onclick="openLeadModal('${contact.id}')" title="View">👁️</button>
                <a href="https://wa.me/91${(contact.phone || '').replace(/\\D/g, '')}" target="_blank" class="action-btn" style="text-decoration: none;" title="WhatsApp">💬</a>
                ${canEdit ? `<button class="action-btn" onclick="quickStatusChange('${contact.id}')" title="Status">🔄</button>` : ''}
                ${userRole === 'super_admin' ? `<button class="action-btn" onclick="confirmDeleteLead('${contact.id}', '${(contact.name || '').replace(/'/g, "\\'")}')" title="Delete" style="color: #EF4444;">🗑️</button>` : ''}
              </div>
            </td>
          </tr>
        `;
      }).join('');
    }

    // Update pagination controls
    function updatePaginationControls() {
      const totalPages = Math.ceil(totalLeads / pageSize);
      const start = (currentPage - 1) * pageSize + 1;
      const end = Math.min(currentPage * pageSize, totalLeads);

      document.getElementById('showingStart').textContent = totalLeads > 0 ? start : 0;
      document.getElementById('showingEnd').textContent = end;
      document.getElementById('totalLeadsCount').textContent = totalLeads;
      document.getElementById('pageIndicator').textContent = `Page ${currentPage} of ${totalPages || 1}`;

      document.getElementById('prevPageBtn').disabled = currentPage <= 1;
      document.getElementById('nextPageBtn').disabled = currentPage >= totalPages;
    }

    // Change page
    function changePage(delta) {
      const newPage = currentPage + delta;
      if (newPage >= 1) {
        loadLeads(newPage, getCurrentFilters());
      }
    }

    // Get current filter values
    function getCurrentFilters() {
      return {
        status: document.getElementById('statusFilter')?.value || 'all',
        priority: document.getElementById('priorityFilter')?.value || 'all',
        search: document.getElementById('searchInput')?.value || ''
      };
    }

    // Initialize on load
    document.addEventListener('DOMContentLoaded', () => {
      loadLeads(1);
    });

    // Modal Functions
    isSuperAdmin = (userRole === 'super_admin');
    let currentLeadId = null;

    // Filter Table
    function filterTable() {
      const search = document.getElementById('globalSearch').value.toLowerCase();
      const status = document.getElementById('statusFilter').value;
      const priority = document.getElementById('priorityFilter').value;

      document.querySelectorAll('.lead-row').forEach(row => {
        const matchSearch = !search || row.dataset.search.includes(search);
        const matchStatus = !status || row.dataset.status === status;
        const matchPriority = !priority || row.dataset.priority === priority;
        row.style.display = (matchSearch && matchStatus && matchPriority) ? '' : 'none';
      });
    }

    // Modal Functions
    async function openLeadModal(id) {
      currentLeadId = id;
      document.getElementById('leadModal').classList.add('active');
      try {
        const res = await fetch('/api/leads/' + id);
        const lead = await res.json();
        renderLeadModal(lead);
      } catch (e) {
        document.getElementById('modalBody').innerHTML = '<p style="color: var(--danger);">Failed to load lead</p>';
      }
    }

    function renderLeadModal(lead) {
      const html = `
        <div style="display: grid; gap: 20px;">
          <div style="display: flex; align-items: flex-start; justify-content: space-between;">
            <div style="display: flex; align-items: center; gap: 16px;">
              <div class="lead-avatar" style="width: 56px; height: 56px; font-size: 20px;">${lead.name.charAt(0).toUpperCase()}</div>
              <div>
                <h3 style="font-size: 20px; font-weight: 700; margin: 0 0 4px 0;">${lead.name}</h3>
                <p style="color: var(--text-muted); margin: 0; font-size: 14px;">${lead.location || 'No location'}</p>
              </div>
            </div>
            <div style="display: flex; gap: 8px;">
              <span class="badge badge-${lead.status || 'new'}">${(lead.status || 'new').charAt(0).toUpperCase() + (lead.status || 'new').slice(1)}</span>
              <span class="badge badge-${lead.priority || 'medium'}">${(lead.priority || 'medium').charAt(0).toUpperCase() + (lead.priority || 'medium').slice(1)}</span>
            </div>
          </div>

          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
            <div style="background: var(--bg); padding: 16px; border-radius: 12px;">
              <p style="font-size: 12px; color: var(--text-muted); margin: 0 0 4px 0;">Phone</p>
              <a href="tel:${lead.phone}" style="color: var(--primary); font-weight: 600; font-size: 16px; text-decoration: none;">${lead.phone}</a>
              <div style="display: flex; gap: 8px; margin-top: 8px;">
                <a href="tel:${lead.phone}" style="font-size: 12px; background: #DCFCE7; color: #16A34A; padding: 4px 12px; border-radius: 6px; text-decoration: none;">📞 Call</a>
                <a href="https://wa.me/91${lead.phone.replace(/\\D/g, '')}" target="_blank" style="font-size: 12px; background: #DCFCE7; color: #16A34A; padding: 4px 12px; border-radius: 6px; text-decoration: none;">💬 WhatsApp</a>
              </div>
            </div>
            <div style="background: var(--bg); padding: 16px; border-radius: 12px;">
              <p style="font-size: 12px; color: var(--text-muted); margin: 0 0 4px 0;">Email</p>
              <p style="font-weight: 500; margin: 0;">${lead.email || '-'}</p>
              ${lead.email ? `<a href="mailto:${lead.email}" style="font-size: 12px; color: var(--primary); margin-top: 8px; display: inline-block;">Send Email →</a>` : ''}
            </div>
          </div>

          <div style="background: var(--bg); padding: 16px; border-radius: 12px;">
            <p style="font-size: 12px; color: var(--text-muted); margin: 0 0 4px 0;">Service Interest</p>
            <p style="font-weight: 500; margin: 0 0 8px 0;">${lead.serviceType || 'Not specified'}</p>
            ${lead.message ? `<p style="font-size: 14px; color: var(--text-muted); margin: 0;">${lead.message}</p>` : ''}
          </div>

          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
            <div>
              <label style="font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 6px;">Status</label>
              ${canEdit ? `<select onchange="updateLeadField('${lead.id}', 'status', this.value)" style="width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px;">
                ${['new','contacted','qualified','proposal','negotiation','converted','lost'].map(s => 
                  `<option value="${s}" ${lead.status === s ? 'selected' : ''}>${s.charAt(0).toUpperCase() + s.slice(1)}</option>`
                ).join('')}
              </select>` : `<span class="badge badge-${lead.status || 'new'}" style="display: inline-block; margin-top: 4px;">${(lead.status || 'new').charAt(0).toUpperCase() + (lead.status || 'new').slice(1)}</span>`}
            </div>
            <div>
              <label style="font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 6px;">Priority</label>
              ${canEdit ? `<select onchange="updateLeadField('${lead.id}', 'priority', this.value)" style="width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px;">
                ${['low','medium','high','urgent'].map(p => 
                  `<option value="${p}" ${lead.priority === p ? 'selected' : ''}>${p.charAt(0).toUpperCase() + p.slice(1)}</option>`
                ).join('')}
              </select>` : `<span class="badge badge-${lead.priority || 'medium'}" style="display: inline-block; margin-top: 4px;">${(lead.priority || 'medium').charAt(0).toUpperCase() + (lead.priority || 'medium').slice(1)}</span>`}
            </div>
          </div>

          ${canEdit ? `<div>
            <label style="font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 6px;">Follow-up Date</label>
            <div style="display: flex; gap: 8px;">
              <input type="date" id="followUpDateInput" value="${lead.followUpDate ? new Date(lead.followUpDate).toISOString().split('T')[0] : ''}" style="flex: 1; padding: 10px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px;">
              <button onclick="setFollowUp('${lead.id}')" style="padding: 10px 20px; background: var(--primary); color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer;">Set</button>
            </div>
          </div>` : (lead.followUpDate ? `<div>
            <label style="font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 6px;">Follow-up Date</label>
            <p style="font-weight: 500; margin: 4px 0 0 0;">${new Date(lead.followUpDate).toLocaleDateString('en-IN')}</p>
          </div>` : '')}

          <div>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
              <label style="font-size: 12px; color: var(--text-muted);">Notes (${(lead.notes || []).length})</label>
            </div>
            <div style="display: grid; gap: 8px; max-height: 200px; overflow-y: auto;">
              ${(lead.notes || []).length ? lead.notes.map(n => `
                <div style="background: var(--bg); padding: 12px; border-radius: 8px;">
                  <p style="margin: 0; font-size: 14px;">${n.content}</p>
                  <p style="margin: 4px 0 0 0; font-size: 11px; color: var(--text-muted);">${n.createdBy || 'Admin'} • ${new Date(n.createdAt).toLocaleString('en-IN')}</p>
                </div>
              `).join('') : '<p style="color: var(--text-muted); font-size: 14px; margin: 0;">No notes yet</p>'}
            </div>
            ${canEdit ? `<textarea id="newNoteContent" placeholder="Add a note..." style="width: 100%; margin-top: 12px; padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; resize: vertical; min-height: 80px;"></textarea>
            <button onclick="saveNote()" style="margin-top: 8px; padding: 10px 20px; background: var(--primary); color: white; border: none; border-radius: 8px; font-weight: 600; cursor: pointer;">Add Note</button>` : ''}
          </div>

          ${canEdit ? `<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
            <div>
              <label style="font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 6px;">Assigned To</label>
              <input type="text" value="${lead.assigned_to || lead.assignedTo || ''}" onchange="updateLeadField('${lead.id}', 'assignedTo', this.value)" placeholder="Enter assignee name" style="width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px;">
            </div>
            <div>
              <label style="font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 6px;">Estimated Value (₹)</label>
              <input type="number" value="${lead.estimated_value || lead.estimatedValue || ''}" onchange="updateLeadField('${lead.id}', 'estimatedValue', this.value)" placeholder="Enter amount" style="width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px;">
            </div>
          </div>` : ''}

          <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 16px; border-top: 1px solid var(--border);">
            <div style="font-size: 12px; color: var(--text-muted);">
              Created: ${lead.created_at || lead.createdAt ? new Date(lead.created_at || lead.createdAt).toLocaleString('en-IN') : 'Unknown'}
              ${lead.source ? ' | Source: ' + lead.source : ''}
            </div>
            ${isSuperAdmin ? `<button onclick="confirmDeleteLead('${lead.id || lead.lead_id}', '${lead.name.replace(/'/g, "\\\\'")}')" style="padding: 8px 16px; background: #FEE2E2; color: #DC2626; border: 1px solid #FECACA; border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 13px;">🗑️ Delete Lead</button>` : ''}
          </div>
        </div>
      `;
      document.getElementById('modalBody').innerHTML = html;
    }

    function closeModal() {
      document.getElementById('leadModal').classList.remove('active');
      currentLeadId = null;
    }

    function quickStatusChange(id) {
      currentLeadId = id;
      document.getElementById('statusModal').classList.add('active');
    }

    function closeStatusModal() {
      document.getElementById('statusModal').classList.remove('active');
    }

    async function setStatus(status) {
      try {
        const res = await fetch(`/api/leads/${currentLeadId}/status`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status })
        });
        if (res.ok) location.reload();
        else alert('Failed to update status');
      } catch (e) { alert('Error: ' + e.message); }
    }

    async function updateLeadField(id, field, value) {
      const endpoint = field === 'status' ? `/api/leads/${id}/status` : 
                       field === 'priority' ? `/api/leads/${id}/priority` : `/api/leads/${id}`;
      const body = { [field]: value };
      try {
        await fetch(endpoint, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
