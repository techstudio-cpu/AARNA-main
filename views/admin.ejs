    function qbAutoBuild() {
      const getVal = (id) => { const el = document.getElementById(id); return el ? el.value : ''; };
      const getNum = (id) => parseFloat(getVal(id)) || 0;
      const cap = getNum('qbCapacity');

      qbData.customerName = getVal('qbCustomerName');
      qbData.location = getVal('qbLocation');
      qbData.projectType = getVal('qbProjectType');
      qbData.capacityKwp = cap;
      qbData.averageMonthlyBill = getNum('qbMonthlyBill');
      qbData.gstRate = 18;

      // Auto date
      if (!qbData.date) qbData.date = new Date().toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });

      // Auto area: ~100 sq ft per kW
      qbData.availableArea = Math.round(cap * 100);

      // Auto generation: 1500 kWh/kW/year
      qbData.totalKwhPerYear = Math.round(cap * 1500);

      // Auto subsidy: PM Surya Ghar — ONLY for Residential, max ₹78,000
      const isResidential = qbData.projectType.toLowerCase().includes('residential');
      if (isResidential) {
        const first3kW = Math.min(cap, 3) * 30000;
        const next7kW = Math.max(0, Math.min(cap - 3, 7)) * 18000;
        qbData.subsidy = Math.min(78000, Math.round(first3kW + next7kW));
      } else {
        qbData.subsidy = 0;
      }

      // Auto cost from components (base + markup + GST)
      const componentBase = qbData.components.reduce((sum, c) => {
        const qty = parseFloat(c.quantity) || 1;
        const price = c.unitPrice || 0;
        const markup = c.markup || 0;
        return sum + (price * qty * (1 + markup / 100));
      }, 0);
      // Add installation & misc costs proportional to capacity
      const installCost = cap * 12000; // ₹12,000/kW installation
      const baseTotal = componentBase + installCost;
      qbData.totalCost = Math.round(baseTotal * 1.18); // incl 18% GST

      // Auto savings
      const ratePerUnit = 10.08;
      qbData.yearlySavings = Math.round(cap * 1500 * ratePerUnit);

      // Auto payback
      const netCost = qbData.totalCost - qbData.subsidy;
      qbData.paybackPeriod = parseFloat((netCost / qbData.yearlySavings).toFixed(1));

      // Update auto summary UI
      const setText = (id, text) => { const el = document.getElementById(id); if (el) el.textContent = text; };
      setText('qbAutoArea', qbData.availableArea.toLocaleString() + ' sq.ft');
      setText('qbAutoGen', qbData.totalKwhPerYear.toLocaleString() + ' kWh');
      setText('qbAutoSubsidy', '₹' + qbData.subsidy.toLocaleString());
      setText('qbAutoPayback', qbData.paybackPeriod + ' yrs');
      setText('qbAutoTotal', '₹' + qbData.totalCost.toLocaleString());

      qbRenderPreview();
    }

    // ─── AI System Recommendation ───
    function qbRecommendSystem() {
      const grid = document.getElementById('qbGridStatus')?.value || 'reliable';
      const backup = document.getElementById('qbBackupNeed')?.value || 'no';

      let recText = '';
      let recReason = '';
      let recValue = '';

      if (grid === 'nogrid') {
        recText = 'Off-Grid Solar';
        recReason = 'No grid connection requires full battery backup & standalone system.';
        recValue = backup === 'yes' ? 'Residential Off-Grid' : 'Residential Off-Grid';
      } else if (grid === 'unreliable' && backup === 'yes') {
        recText = 'Hybrid Solar';
        recReason = 'Unreliable grid + battery backup = best of both worlds.';
        recValue = 'Residential Hybrid';
      } else if (grid === 'reliable' && backup === 'yes') {
        recText = 'Hybrid Solar';
        recReason = 'Reliable grid but backup need suggests hybrid for night/outage power.';
        recValue = 'Residential Hybrid';
      } else {
        recText = 'On-Grid Solar';
        recReason = 'Reliable grid with no backup need = lowest cost, net metering benefit.';
        recValue = 'Residential On-Grid';
      }

      const isCommercial = qbData.projectType.toLowerCase().includes('commercial');
      const isIndustrial = qbData.projectType.toLowerCase().includes('industrial');
      if (isCommercial) recValue = recValue.replace('Residential', 'Commercial');
      if (isIndustrial) recValue = 'Industrial On-Grid';

      const recEl = document.getElementById('qbAiRecText');
      const reasonEl = document.getElementById('qbAiRecReason');
      if (recEl) recEl.textContent = recText;
      if (reasonEl) reasonEl.textContent = recReason;

      // Auto-select the recommended type if user hasn't manually overridden recently
      const ptEl = document.getElementById('qbProjectType');
      if (ptEl) ptEl.value = recValue;

      qbAutoBuild();
    }

    // ─── Fetch Aarna AI Recommendation ───
    async function qbFetchAIRecommendation() {
      const btn = document.getElementById('qbAiBtn');
      if (btn) btn.innerHTML = '<span class="qb-spinner"></span> Asking Aarna AI...';

      try {
        const res = await fetch('/api/ai/recommend-system', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            gridStatus: document.getElementById('qbGridStatus')?.value || 'reliable',
            backupNeed: document.getElementById('qbBackupNeed')?.value || 'no',
            capacityKwp: parseFloat(document.getElementById('qbCapacity')?.value) || 5,
            monthlyBill: parseFloat(document.getElementById('qbMonthlyBill')?.value) || 6500,
            location: qbData.location,
            installationType: qbData.projectType
          })
        });

        const data = await res.json();
        if (data.success && data.recommendation) {
          const rec = data.recommendation;
          const recEl = document.getElementById('qbAiRecText');
          const reasonEl = document.getElementById('qbAiRecReason');
          if (recEl) recEl.textContent = rec.recommendedSystem + ' Solar';
          if (reasonEl) reasonEl.textContent = 'Aarna AI: ' + rec.reasoning;

          // Auto-select the recommended installation type
          const ptEl = document.getElementById('qbProjectType');
          if (ptEl && rec.recommendedType) ptEl.value = rec.recommendedType;

          qbAutoBuild();
        } else {
          alert('AI service unavailable. Using rule-based recommendation instead.');
        }
      } catch (err) {
        console.error('[AI] Fetch error:', err);
        alert('AI service unavailable. Using rule-based recommendation instead.');
      } finally {
        if (btn) btn.innerHTML = '✨ Get Aarna AI Recommendation';
      }
    }

