        isOptional: false
      });
      qbRenderComponents();
      qbAutoBuild();
    }

    function qbRemoveComponent(id) {
      qbData.components = qbData.components.filter(c => c.id !== id);
      qbRenderComponents();
      qbAutoBuild();
    }

    function qbUpdateComponent(id, field, value) {
      const comp = qbData.components.find(c => c.id === id);
      if (comp) comp[field] = value;
      qbAutoBuild();
    }

    // ─── Option C: Pricing & Discounts ───
    
    // Discount codes database
    const qbDiscountCodes = {
      'SOLAR10': { type: 'percentage', value: 10, label: 'SOLAR10 (10% off)' },
      'SOLAR15': { type: 'percentage', value: 15, label: 'SOLAR15 (15% off)' },
      'NEWCUST': { type: 'percentage', value: 5, label: 'NEWCUST (5% off)' },
      'FLAT5000': { type: 'flat', value: 5000, label: 'FLAT5000 (₹5,000 off)' },
      'FLAT10000': { type: 'flat', value: 10000, label: 'FLAT10000 (₹10,000 off)' },
      'REFERRAL': { type: 'percentage', value: 8, label: 'REFERRAL (8% off)' }
    };

    function qbCalculatePricing() {
      const components = qbData.components || [];
      let baseCost = 0;
      let optionalCost = 0;
      
      components.forEach(c => {
        const price = c.unitPrice || 0;
        const markup = c.markup || 0;
        const finalPrice = Math.round(price * (1 + markup / 100));
        
        if (c.isOptional) {
          optionalCost += finalPrice;
        } else {
          baseCost += finalPrice;
        }
      });
      
      const subtotal = baseCost + optionalCost;
      
      // Apply discount
      let discountAmount = 0;
      let discountLabel = '';
      if (qbData.activeDiscount) {
        const discount = qbDiscountCodes[qbData.activeDiscount];
        if (discount) {
          discountLabel = discount.label;
          if (discount.type === 'percentage') {
            discountAmount = Math.round(subtotal * discount.value / 100);
          } else {
            discountAmount = Math.min(discount.value, subtotal); // Don't exceed subtotal
          }
        }
      }
      
      const afterDiscount = subtotal - discountAmount;
      
      // Apply GST
      const gstRate = qbData.gstRate !== undefined ? qbData.gstRate : 18;
      const gstAmount = Math.round(afterDiscount * gstRate / 100);
      
      const finalTotal = afterDiscount + gstAmount;
      
      return {
        baseCost,
        optionalCost,
        subtotal,
        discountAmount,
        discountLabel,
        gstRate,
        gstAmount,
        finalTotal
      };
    }

    function qbUpdatePricingDisplay() {
      // Simplified - pricing is now shown directly in preview only
      return qbCalculatePricing();
    }

    function qbSetPackageTier(tier) {
      qbData.packageTier = tier;
      
      // Update UI
      document.querySelectorAll('.qb-tier-option').forEach(el => {
        el.classList.remove('qb-tier-selected');
      });
      document.querySelector(`.qb-tier-option[data-tier="${tier}"]`).classList.add('qb-tier-selected');
      
      // Toggle optional components based on tier
      const components = qbData.components || [];
      components.forEach(c => {
        if (tier === 'basic') {
          // Disable all optional components
          c.isOptional = false;
        } else if (tier === 'premium') {
          // Enable all optional components
          if (c.unitPrice < 50000) { // Only small items
            c.isOptional = true;
          }
        }
        // Standard keeps current state
      });
      
      qbRenderComponents();
      qbUpdatePricingDisplay();
    }

    function qbValidateDiscountCode(code) {
      const status = document.getElementById('qbDiscountStatus');
      if (!code) {
        status.textContent = '';
        status.className = 'qb-discount-status';
        return;
      }
      
      const upperCode = code.toUpperCase();
      if (qbDiscountCodes[upperCode]) {
        status.textContent = '✓ Valid code: ' + qbDiscountCodes[upperCode].label;
        status.className = 'qb-discount-status qb-discount-valid';
      } else {
        status.textContent = '✗ Invalid code';
        status.className = 'qb-discount-status qb-discount-invalid';
      }
    }

