            <!-- Right: Preview Area -->
            <div class="qb-preview-area">
              <div class="qb-preview-scroll">
                <div class="qb-preview-pages" id="qbPreviewPages"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Off-screen PDF capture container -->
