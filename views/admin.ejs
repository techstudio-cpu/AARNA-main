                    <div style="background: var(--bg); padding: 10px; border-radius: 8px; text-align:center;">
                      <p style="font-size:10px; color: #64748b; text-transform:uppercase; font-weight:700;">Area Needed</p>
                      <p style="font-size:18px; font-weight:800; color: var(--text); margin-top:2px;" id="qbAutoArea">500 sq.ft</p>
                    </div>
                    <div style="background: var(--bg); padding: 10px; border-radius: 8px; text-align:center;">
                      <p style="font-size:10px; color: #64748b; text-transform:uppercase; font-weight:700;">Yearly Generation</p>
                      <p style="font-size:18px; font-weight:800; color: var(--text); margin-top:2px;" id="qbAutoGen">7,500 kWh</p>
                    </div>
                    <div style="background: var(--bg); padding: 10px; border-radius: 8px; text-align:center;">
                      <p style="font-size:10px; color: #64748b; text-transform:uppercase; font-weight:700;">Govt. Subsidy</p>
                      <p style="font-size:18px; font-weight:800; color: var(--primary); margin-top:2px;" id="qbAutoSubsidy">₹78,000</p>
                    </div>
                    <div style="background: var(--bg); padding: 10px; border-radius: 8px; text-align:center;">
                      <p style="font-size:10px; color: #64748b; text-transform:uppercase; font-weight:700;">Payback Period</p>
                      <p style="font-size:18px; font-weight:800; color: var(--text); margin-top:2px;" id="qbAutoPayback">4.5 yrs</p>
                    </div>
                  </div>
                  <div style="margin-top:10px; background: var(--bg); padding: 12px; border-radius: 8px; text-align:center;">
                    <p style="font-size:10px; color: #64748b; text-transform:uppercase; font-weight:700;">Estimated Total Cost (Incl. GST 18%)</p>
                    <p style="font-size:24px; font-weight:900; color: var(--primary); margin-top:2px;" id="qbAutoTotal">₹2,85,000</p>
                  </div>
                </div>
              </div>

              <div>
                <!-- Components -->
                <div class="qb-form-section">
                  <div class="qb-form-section-title" style="display: flex; justify-content: space-between; align-items: center;">
                    Project Components
                    <button class="qb-add-btn" onclick="qbAddComponent()">+ Add</button>
                  </div>
                  <div id="qbComponentsList"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Preview -->
        <div id="qbPreviewView" style="display: none;">
          <div class="qb-preview-layout">
            <!-- Left: Design Panel -->
            <div class="qb-design-panel">
              <!-- Quick Theme Selector -->
              <div class="qb-design-section">
                <div class="qb-design-title">Quick Theme</div>
                <div class="qb-theme-chips">
                  <button class="qb-theme-chip" onclick="qbSelectTheme('default')" id="previewThemeDefault">Default</button>
                  <button class="qb-theme-chip" onclick="qbSelectTheme('ocean')" id="previewThemeOcean">Ocean</button>
                  <button class="qb-theme-chip" onclick="qbSelectTheme('forest')" id="previewThemeForest">Forest</button>
                  <button class="qb-theme-chip" onclick="qbSelectTheme('sunset')" id="previewThemeSunset">Sunset</button>
                  <button class="qb-theme-chip" onclick="qbSelectTheme('royal')" id="previewThemeRoyal">Royal</button>
                  <button class="qb-theme-chip" onclick="qbSelectTheme('dark')" id="previewThemeDark">Dark</button>
                </div>
