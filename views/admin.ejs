        <textarea id="qbTemplateDescription" rows="3" placeholder="Brief description of this template..."></textarea>
      </div>
      <div class="qb-modal-actions">
        <button class="qb-modal-btn qb-modal-btn-secondary" onclick="qbHideSaveTemplateModal()">Cancel</button>
        <button class="qb-modal-btn qb-modal-btn-primary" onclick="qbSaveTemplate()">Save Template</button>
      </div>
    </div>
  </div>

  <!-- Users Management Modal (super_admin only) -->
  <div id="usersModal" class="modal">
    <div class="modal-content" style="max-width: 700px;">
      <div class="modal-header">
        <h2>User Management</h2>
        <button class="modal-close" onclick="closeUsersModal()">&times;</button>
      </div>
      <div class="modal-body">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
          <p style="font-size: 13px; color: var(--text-muted); margin: 0;">Manage admin panel users and their roles</p>
          <button onclick="showAddUserForm()" style="padding: 8px 16px; background: var(--primary); color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 13px;">+ Add User</button>
        </div>

        <!-- Add User Form (hidden by default) -->
        <div id="addUserForm" style="display: none; background: var(--bg); border-radius: 12px; padding: 20px; margin-bottom: 20px; border: 1px solid var(--border);">
          <div style="font-weight: 600; font-size: 14px; margin-bottom: 16px;">New User</div>
          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;">
            <div>
              <label style="font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 4px;">Display Name *</label>
              <input type="text" id="newUserName" style="width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 13px;" placeholder="Full name">
            </div>
            <div>
              <label style="font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 4px;">Username *</label>
              <input type="text" id="newUserUsername" style="width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 13px;" placeholder="Login username">
            </div>
            <div>
              <label style="font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 4px;">Password *</label>
              <input type="password" id="newUserPassword" style="width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 13px;" placeholder="Secure password">
            </div>
            <div>
              <label style="font-size: 12px; color: var(--text-muted); display: block; margin-bottom: 4px;">Role *</label>
              <select id="newUserRole" style="width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 13px;">
                <option value="viewer">Viewer (read-only)</option>
                <option value="manager">Manager (edit leads)</option>
                <option value="super_admin">Super Admin (full access)</option>
              </select>
            </div>
          </div>
          <div style="display: flex; gap: 8px; justify-content: flex-end; margin-top: 16px;">
            <button onclick="hideAddUserForm()" style="padding: 8px 16px; border: 1px solid var(--border); background: white; border-radius: 8px; cursor: pointer; font-size: 13px;">Cancel</button>
            <button onclick="createUser()" style="padding: 8px 16px; background: var(--primary); color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 13px;">Create User</button>
          </div>
        </div>

        <!-- Users List -->
        <div id="usersList" style="display: grid; gap: 8px;">
          <p style="color: var(--text-muted); text-align: center; padding: 20px;">Loading users...</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Audit Log Modal (super_admin only) -->
  <div id="auditModal" class="modal">
    <div class="modal-content" style="max-width: 900px;">
      <div class="modal-header">
        <h2>Audit Log</h2>
        <button class="modal-close" onclick="closeAuditModal()">&times;</button>
      </div>
      <div class="modal-body">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 12px;">
          <p style="font-size: 13px; color: var(--text-muted); margin: 0;">System activity and security events</p>
          <div style="display: flex; gap: 8px; align-items: center;">
            <select id="auditActionFilter" style="padding: 6px 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 12px;">
              <option value="">All Actions</option>
              <option value="LOGIN_SUCCESS">Login Success</option>
              <option value="LOGIN_FAILED">Login Failed</option>
              <option value="LOGIN_FAILED_INACTIVE">Login Failed (Inactive)</option>
              <option value="LOGOUT">Logout</option>
              <option value="USER_CREATED">User Created</option>
              <option value="USER_UPDATED">User Updated</option>
              <option value="USER_DELETED">User Deleted</option>
              <option value="SESSIONS_INVALIDATED">Sessions Invalidated</option>
              <option value="LEAD_DELETED">Lead Deleted</option>
              <option value="BULK_LEADS_DELETED">Bulk Leads Deleted</option>
              <option value="BULK_LEADS_UPDATED">Bulk Leads Updated</option>
              <option value="LEADS_EXPORTED">Leads Exported</option>
            </select>
            <select id="auditUserFilter" style="padding: 6px 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 12px;">
              <option value="">All Users</option>
            </select>
            <button onclick="loadAuditLog()" style="padding: 6px 12px; background: var(--primary); color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 12px;">Refresh</button>
          </div>
        </div>

        <div id="auditLogList" style="max-height: 500px; overflow-y: auto;">
          <p style="color: var(--text-muted); text-align: center; padding: 20px;">Loading audit log...</p>
        </div>
