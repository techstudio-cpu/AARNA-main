    async function loadAuditLog() {
      const actionFilter = document.getElementById('auditActionFilter').value;
      const userFilter = document.getElementById('auditUserFilter').value;
      
      try {
        const params = new URLSearchParams({ limit: 200 });
        if (actionFilter) params.append('action', actionFilter);
        if (userFilter) params.append('userId', userFilter);
        
        const res = await fetch('/api/audit?' + params.toString());
        if (!res.ok) throw new Error('Server returned ' + res.status);
        const data = await res.json();
        const container = document.getElementById('auditLogList');
        
        if (!data.entries || !data.entries.length) {
          container.innerHTML = '<p style="color: var(--text-muted); text-align: center; padding: 20px;">No audit entries found</p>';
          return;
        }
        
        container.innerHTML = data.entries.map(entry => {
          const date = new Date(entry.createdAt || entry.timestamp || entry.created_at).toLocaleString('en-IN');
          const details = entry.details || {};
          const actionColors = {
            LOGIN_SUCCESS: '#10B981',
            LOGIN_FAILED: '#EF4444',
            LOGIN_FAILED_INACTIVE: '#EF4444',
            LOGOUT: '#6B7280',
            USER_CREATED: '#3B82F6',
            USER_UPDATED: '#F59E0B',
            USER_DELETED: '#EF4444',
            SESSIONS_INVALIDATED: '#8B5CF6',
            LEAD_DELETED: '#EF4444',
            BULK_LEADS_DELETED: '#EF4444',
            BULK_LEADS_UPDATED: '#F59E0B',
            LEADS_EXPORTED: '#10B981'
          };
          const color = actionColors[entry.action] || '#6B7280';
          
          return `
            <div style="display: flex; align-items: start; gap: 12px; padding: 12px; background: var(--bg); border-radius: 8px; border: 1px solid var(--border); margin-bottom: 8px;">
              <div style="width: 3px; min-height: 40px; background: ${color}; border-radius: 2px; margin-top: 4px;"></div>
              <div style="flex: 1; min-width: 0;">
                <div style="display: flex; justify-content: space-between; align-items: start; gap: 12px; margin-bottom: 4px;">
                  <span style="font-weight: 600; font-size: 13px; color: ${color};">${entry.action.replace(/_/g, ' ')}</span>
                  <span style="font-size: 11px; color: var(--text-muted); white-space: nowrap;">${date}</span>
                </div>
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 4px;">
                  User: ${entry.userId || 'System'} | IP: ${entry.ipAddress || details.ip || 'N/A'}
                </div>
                ${details.username ? `<div style="font-size: 12px; color: var(--text-muted);">Username: ${details.username}</div>` : ''}
                ${details.targetUserId ? `<div style="font-size: 12px; color: var(--text-muted);">Target: ${details.targetUserId}</div>` : ''}
                ${details.reason ? `<div style="font-size: 12px; color: var(--text-muted);">Reason: ${details.reason}</div>` : ''}
                ${details.leadName ? `<div style="font-size: 12px; color: var(--text-muted);">Lead: ${details.leadName}</div>` : ''}
                ${details.count ? `<div style="font-size: 12px; color: var(--text-muted);">Count: ${details.count}</div>` : ''}
              </div>
            </div>
          `;
        }).join('');
      } catch (e) {
        console.error('Audit log load error:', e);
        document.getElementById('auditLogList').innerHTML = '<p style="color: var(--danger); text-align: center; padding: 20px;">Failed to load audit log</p>';
      }
    }

