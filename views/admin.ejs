    async function qbScheduleReminder() {
      const quotationId = qbCurrentQuotationId;
      if (!quotationId) {
        showToast('Please save the quotation first', 'error');
        return;
      }
      
      const days = prompt('Schedule reminder after how many days?', '7');
      if (!days) return;
      
      try {
        // Log as client activity
        await fetch('/api/clients/activities', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            client_id: qbSelectedClient ? qbSelectedClient.id : null,
            activity_type: 'follow_up',
            description: `Reminder scheduled in ${days} days for quotation ${quotationId}`,
            due_date: qbCalculateReminderDate(parseInt(days)),
            quotation_id: quotationId
          })
        });
        
        showToast(`⏰ Reminder scheduled in ${days} days`, 'success');
      } catch (err) {
        console.error('Error scheduling reminder:', err);
        showToast('Failed to schedule reminder', 'error');
      }
    }

