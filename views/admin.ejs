          <button onclick="setStatus('proposal')" class="badge badge-proposal" style="border: none; padding: 12px; cursor: pointer; font-size: 14px;">Proposal</button>
          <button onclick="setStatus('negotiation')" class="badge badge-negotiation" style="border: none; padding: 12px; cursor: pointer; font-size: 14px;">Negotiation</button>
          <button onclick="setStatus('converted')" class="badge badge-converted" style="border: none; padding: 12px; cursor: pointer; font-size: 14px;">Converted</button>
          <button onclick="setStatus('lost')" class="badge badge-lost" style="border: none; padding: 12px; cursor: pointer; font-size: 14px; grid-column: span 2;">Lost</button>
