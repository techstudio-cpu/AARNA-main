          <div style="flex: 1;"></div>
          <button onclick="exportLeadsCSV()" style="padding: 5px 12px; background: white; border: 1px solid #D97706; color: #92400E; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 500;">📥 Export CSV</button>
          <button onclick="openSystemInfo()" style="padding: 5px 12px; background: white; border: 1px solid #D97706; color: #92400E; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 500;">🖥️ System</button>
