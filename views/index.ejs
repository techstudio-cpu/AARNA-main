<script>
  document.getElementById('callbackForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const phone = this.phone.value;
    const msgEl = document.getElementById('callbackMessage');
    
    try {
      const res = await fetch('/api/callback', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone })
      });
      const data = await res.json();
      msgEl.textContent = data.message;
      msgEl.classList.remove('hidden', 'text-red-600');
      msgEl.classList.add('text-green-600');
      this.reset();
    } catch (err) {
      msgEl.textContent = 'Failed to submit. Please try again.';
      msgEl.classList.remove('hidden', 'text-green-600');
      msgEl.classList.add('text-red-600');
    }
  });
</script>

<!-- WhatsApp Popup Script -->
<script>
let whatsappPopupShown = false;

function showWhatsAppPopup() {
  if (!whatsappPopupShown) {
    document.getElementById('whatsappPopup').classList.remove('hidden');
    whatsappPopupShown = true;
  }
}

function closeWhatsAppPopup() {
  document.getElementById('whatsappPopup').classList.add('hidden');
}

// Show popup after scrolling 30% of the page
window.addEventListener('scroll', function() {
  const scrollPercent = (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100;
  if (scrollPercent > 30 && !whatsappPopupShown) {
    showWhatsAppPopup();
  }
});
</script>

