<%- include('partials/header') %>

<!-- Hero Section -->
<section class="relative min-h-[200px] sm:min-h-[260px] py-14 sm:py-24 overflow-hidden">
  <img src="https://images.unsplash.com/photo-1508514177221-188b1cf16e9d?w=1600&q=80" alt="Solar calculator" class="absolute inset-0 w-full h-full object-cover object-center">
  <div class="absolute inset-0 bg-gradient-to-br from-solar-green/85 to-teal-800/85"></div>
  <div class="relative container mx-auto px-4 text-center text-white">
    <h1 class="text-2xl sm:text-4xl md:text-5xl font-bold mb-3 sm:mb-4">Solar <span class="text-solar-orange">Cost Calculator</span></h1>
    <p class="text-sm sm:text-xl text-gray-200 max-w-2xl mx-auto">Calculate your solar system cost in 30 seconds. Compare On-Grid, Off-Grid & Hybrid options.</p>
  </div>
</section>

<!-- Calculator Section -->
<section class="py-10 sm:py-16 bg-gray-50">
  <div class="container mx-auto px-4 max-w-5xl">

    <!-- Input Card -->
    <div class="bg-white rounded-2xl shadow-lg p-6 sm:p-10 mb-8">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-6 text-center">Enter Your Electricity Details</h2>

      <!-- Tabs -->
      <div class="flex justify-center mb-6">
        <div class="inline-flex bg-gray-100 rounded-full p-1">
          <button id="tabBill" onclick="switchTab('bill')" class="px-5 py-2 rounded-full text-sm font-semibold bg-solar-green text-white transition">By Monthly Bill</button>
          <button id="tabIvrs" onclick="switchTab('ivrs')" class="px-5 py-2 rounded-full text-sm font-semibold text-gray-600 hover:text-solar-green transition">By IVRS Number</button>
        </div>
      </div>

      <!-- Bill Input -->
      <div id="panelBill" class="">
        <div class="grid sm:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Average Monthly Bill (₹)</label>
            <input type="number" id="monthlyBill" value="3000" min="500" max="50000" step="100"
              class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-solar-orange focus:outline-none text-lg font-bold text-gray-800"
              oninput="calculateSolar()">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Electricity Provider</label>
            <select id="provider" class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-solar-orange focus:outline-none text-gray-700" onchange="calculateSolar()">
              <option value="mppkvvcl">MPPKVVCL (M.P. Poorv Kshetra)</option>
              <option value="mpmkvvcl">MPMKVVCL (M.P. Madhya Kshetra)</option>
              <option value="apdcl">APDCL</option>
              <option value="other">Other / Private</option>
            </select>
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Phase</label>
            <select id="phase" class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-solar-orange focus:outline-none text-gray-700" onchange="calculateSolar()">
              <option value="single">Single Phase (Home)</option>
              <option value="three">Three Phase (Commercial/Industrial)</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Location</label>
            <input type="text" id="calcLocation" value="Satna, M.P." class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-solar-orange focus:outline-none text-gray-700">
          </div>
        </div>
      </div>

      <!-- IVRS Input -->
      <div id="panelIvrs" class="hidden">
        <div class="grid sm:grid-cols-3 gap-4 mb-4">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Electricity Provider</label>
            <select id="providerIvrsSelect" class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-solar-orange focus:outline-none text-gray-700">
              <option value="mppkvvcl">MPPKVVCL (M.P. Poorv)</option>
              <option value="mpmkvvcl">MPMKVVCL (M.P. Madhya)</option>
              <option value="apdcl">APDCL</option>
              <option value="other">Other / Private</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">IVRS / Consumer Number</label>
            <input type="text" id="ivrsNumber" placeholder="e.g. 1904011146" maxlength="15"
              class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-solar-orange focus:outline-none text-lg font-bold text-gray-800 uppercase">
          </div>
          <div class="flex items-end">
            <button onclick="fetchBillByIvrs()" id="fetchBillBtn"
              class="w-full bg-solar-orange text-white px-4 py-3 rounded-xl font-semibold hover:bg-orange-600 transition flex items-center justify-center gap-2">
              <span>🔍</span> Fetch Bill
            </button>
          </div>
        </div>
        <p class="text-xs text-gray-500 mb-4">Enter your electricity bill consumer/IVRS number to auto-fetch your last bill amount.</p>

        <!-- Error Display -->
        <div id="billErrorDisplay" class="hidden bg-red-50 border border-red-200 rounded-xl p-4 mb-4">
          <p class="text-sm text-red-700 font-semibold" id="billErrorTitle">Unable to Fetch Bill</p>
          <p class="text-xs text-red-600 mt-1" id="billErrorText"></p>
          <div id="billErrorHelp" class="hidden mt-3 pt-3 border-t border-red-200">
            <p class="text-xs text-red-700 font-semibold mb-1">To enable real bill fetching:</p>
            <ul class="text-xs text-red-600 list-disc list-inside space-y-1" id="billErrorSteps"></ul>
          </div>
        </div>

        <!-- Fetched Bill Display -->
        <div id="fetchedBillDisplay" class="hidden bg-green-50 border border-green-200 rounded-xl p-4 mb-4">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-green-700 font-semibold">Bill Fetched Successfully</p>
              <p class="text-xs text-green-600">Consumer: <span id="fetchedConsumer"></span> | Month: <span id="fetchedMonth"></span></p>
            </div>
            <div class="text-right">
              <p class="text-2xl font-bold text-green-700">₹<span id="fetchedAmount">0</span></p>
              <p class="text-xs text-green-600">Units: <span id="fetchedUnits">0</span> kWh</p>
            </div>
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Phase</label>
            <select id="phaseIvrs" class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-solar-orange focus:outline-none text-gray-700" onchange="calculateSolar()">
              <option value="single">Single Phase (Home)</option>
              <option value="three">Three Phase (Commercial/Industrial)</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Location</label>
            <input type="text" id="calcLocationIvrs" value="Satna, M.P." class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-solar-orange focus:outline-none text-gray-700">
          </div>
        </div>
      </div>

      <div class="mt-6 pt-6 border-t border-gray-100">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm text-gray-600">Estimated Monthly Consumption</span>
          <span class="text-lg font-bold text-solar-green"><span id="estConsumption">0</span> kWh</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div id="consumptionBar" class="bg-solar-green h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
        </div>
      </div>
    </div>

    <!-- Results Cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-10" id="resultCards">

      <!-- On-Grid -->
