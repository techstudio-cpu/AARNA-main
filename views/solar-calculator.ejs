    <!-- Aarna AI Recommendation Widget -->
    <div class="bg-gradient-to-br from-solar-green to-teal-700 rounded-2xl shadow-lg p-6 sm:p-8 text-white mb-10">
      <div class="text-center mb-6">
        <h3 class="text-xl sm:text-2xl font-bold mb-2">🤖 Not Sure Which System to Choose?</h3>
        <p class="text-gray-200 text-sm sm:text-base">Let Aarna AI recommend the perfect solar system for your needs.</p>
      </div>

      <div class="grid sm:grid-cols-2 gap-4 max-w-2xl mx-auto mb-6">
        <div>
          <label class="block text-sm font-medium text-gray-200 mb-2">Grid Availability</label>
          <select id="aiGridStatus" class="w-full px-4 py-3 bg-white/15 border border-white/20 rounded-xl text-white focus:outline-none focus:border-white/40">
            <option value="reliable" style="color:#1e293b;">Reliable Grid (city/town)</option>
            <option value="unreliable" style="color:#1e293b;">Unreliable / Frequent outages</option>
            <option value="nogrid" style="color:#1e293b;">No Grid (remote area)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-200 mb-2">Need Battery Backup?</label>
          <select id="aiBackupNeed" class="w-full px-4 py-3 bg-white/15 border border-white/20 rounded-xl text-white focus:outline-none focus:border-white/40">
            <option value="no" style="color:#1e293b;">No — Grid is sufficient</option>
            <option value="yes" style="color:#1e293b;">Yes — Need power at night/outages</option>
          </select>
        </div>
      </div>

      <div class="text-center">
        <button onclick="getAarnaAIRec()" id="aarnaAiBtn"
          class="bg-white text-solar-green px-8 py-3 rounded-full font-bold hover:bg-gray-100 transition shadow-lg inline-flex items-center gap-2">
          <span>✨</span> Get Aarna AI Recommendation
        </button>
      </div>

      <div id="aarnaAiResult" class="hidden mt-6 bg-white/10 rounded-xl p-5 max-w-2xl mx-auto text-center">
        <p class="text-xs uppercase tracking-widest text-gray-300 mb-1">Aarna AI Recommends</p>
        <p class="text-2xl font-bold mb-2" id="aarnaAiRecText">On-Grid Solar</p>
        <p class="text-sm text-gray-200 leading-relaxed" id="aarnaAiRecReason">Best for areas with reliable grid and net metering benefits.</p>
        <div class="mt-4 flex flex-wrap justify-center gap-2" id="aarnaAiTags"></div>
