              <span class="font-bold text-solar-orange">₹<span id="hybridSavings">0</span></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">Payback Period</span>
              <span class="font-bold text-gray-800"><span id="hybridPayback">0</span> yrs</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">Area Required</span>
              <span class="font-bold text-gray-800"><span id="hybridArea">0</span> sq.ft</span>
