            </div>
          </div>

          <div class="space-y-3 mb-4">
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">Recommended Capacity</span>
              <span class="font-bold text-gray-800" id="offgridCapacity">0 kWp</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-600">System Cost</span>
