      <!-- Off-Grid -->
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden border-t-4 border-solar-orange">
        <div class="p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-solar-orange/10 rounded-full flex items-center justify-center text-solar-orange text-lg">🔋</div>
            <div>
              <h3 class="text-lg font-bold text-gray-800">Off-Grid Solar</h3>
