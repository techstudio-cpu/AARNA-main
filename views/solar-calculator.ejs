<script>
  // ─── Tab Switching ───
  function switchTab(tab) {
    document.getElementById('panelBill').classList.toggle('hidden', tab !== 'bill');
    document.getElementById('panelIvrs').classList.toggle('hidden', tab !== 'ivrs');
    document.getElementById('tabBill').className = tab === 'bill'
      ? 'px-5 py-2 rounded-full text-sm font-semibold bg-solar-green text-white transition'
      : 'px-5 py-2 rounded-full text-sm font-semibold text-gray-600 hover:text-solar-green transition';
    document.getElementById('tabIvrs').className = tab === 'ivrs'
      ? 'px-5 py-2 rounded-full text-sm font-semibold bg-solar-green text-white transition'
      : 'px-5 py-2 rounded-full text-sm font-semibold text-gray-600 hover:text-solar-green transition';
  }

  // ─── IVRS Bill Fetch (Real API) ───
  async function fetchBillByIvrs() {
    const ivrs = document.getElementById('ivrsNumber').value.trim();
    const provider = document.getElementById('providerIvrsSelect').value;
    if (!ivrs || ivrs.length < 5) {
      alert('Please enter a valid IVRS/Consumer number');
      return;
    }

    const btn = document.getElementById('fetchBillBtn');
    const errorDisplay = document.getElementById('billErrorDisplay');
    const successDisplay = document.getElementById('fetchedBillDisplay');
    const errorHelp = document.getElementById('billErrorHelp');
    const errorSteps = document.getElementById('billErrorSteps');

    // Reset displays
    errorDisplay.classList.add('hidden');
    successDisplay.classList.add('hidden');
    btn.innerHTML = '<span class="animate-spin inline-block">⟳</span> Fetching...';
    btn.disabled = true;

    try {
      const res = await fetch('/api/bill/fetch', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ provider, consumerNumber: ivrs })
      });

      const data = await res.json();

      if (data.success && data.bill) {
        // Real bill fetched
        const bill = data.bill;
        document.getElementById('fetchedConsumer').textContent = bill.consumerNumber || ivrs;
        document.getElementById('fetchedMonth').textContent = bill.billMonth || 'Current';
        document.getElementById('fetchedAmount').textContent = (bill.amount || 0).toLocaleString();
        document.getElementById('fetchedUnits').textContent = bill.units || Math.round((bill.amount || 0) / 7.5);
        successDisplay.classList.remove('hidden');

        // Auto-fill bill amount
        document.getElementById('monthlyBill').value = bill.amount || 0;
        btn.innerHTML = '<span>✓</span> Bill Fetched';
        calculateSolar();
      } else {
        // Show real error with integration help
        document.getElementById('billErrorTitle').textContent = data.error || 'Unable to Fetch Bill';
        document.getElementById('billErrorText').textContent = data.integrationNote ||
          'Real-time bill fetch requires a BBPS API or electricity provider integration.';

        if (data.howToIntegrate && data.howToIntegrate.length) {
          errorSteps.innerHTML = data.howToIntegrate.map(s => `<li>${s}</li>`).join('');
          errorHelp.classList.remove('hidden');
        } else {
          errorHelp.classList.add('hidden');
        }
        errorDisplay.classList.remove('hidden');
        btn.innerHTML = '<span>🔍</span> Fetch Bill';
      }
    } catch (err) {
      console.error('[BillFetch] Error:', err);
      document.getElementById('billErrorTitle').textContent = 'Connection Error';
      document.getElementById('billErrorText').textContent = 'Could not connect to bill fetch service. Please try again or enter your bill manually.';
      errorHelp.classList.add('hidden');
      errorDisplay.classList.remove('hidden');
      btn.innerHTML = '<span>🔍</span> Fetch Bill';
    } finally {
      btn.disabled = false;
    }
  }

  // ─── Solar Cost Calculator ───
  function calculateSolar() {
    const bill = parseFloat(document.getElementById('monthlyBill').value) || 0;
    const phase = document.getElementById('phase').value;
    const isResidential = phase === 'single';

    // Reverse-calculate consumption from bill (avg ₹7.5/unit for residential, ₹9 for commercial)
    const avgRate = isResidential ? 7.5 : 9.0;
    const monthlyKwh = Math.round(bill / avgRate);
    const yearlyKwh = monthlyKwh * 12;

    // Update consumption display
    document.getElementById('estConsumption').textContent = monthlyKwh.toLocaleString();
    const maxRef = 1500; // reference max for bar
    const pct = Math.min(100, (monthlyKwh / maxRef) * 100);
    document.getElementById('consumptionBar').style.width = pct + '%';

    // Calculate required capacity: 1 kWp generates ~1500 kWh/year in MP
    // But we want to offset the bill, not full consumption
    // Target: offset ~80% of bill for optimal ROI
    const targetYearlyKwh = yearlyKwh * 0.8;
    const capacity = Math.max(1, Math.round((targetYearlyKwh / 1500) * 10) / 10);

    // Per-kWp costs
    const onGridRate = 58000;
    const offGridRate = 95000;
    const hybridRate = 78000;

    // Subsidy: only residential on-grid, max ₹78,000
    let subsidy = 0;
    if (isResidential) {
      const first3 = Math.min(capacity, 3) * 30000;
      const next7 = Math.max(0, Math.min(capacity - 3, 7)) * 18000;
      subsidy = Math.min(78000, Math.round(first3 + next7));
    }

    // Costs
    const onGridCost = Math.round(capacity * onGridRate);
    const offGridCost = Math.round(capacity * offGridRate);
    const hybridCost = Math.round(capacity * hybridRate);

    // Savings (₹10.08 avg rate for solar generation value)
    const yearlySavings = Math.round(capacity * 1500 * 10.08);

    // Payback
    const onGridPayback = ((onGridCost - subsidy) / yearlySavings).toFixed(1);
    const offGridPayback = (offGridCost / yearlySavings).toFixed(1);
    const hybridPayback = (hybridCost / yearlySavings).toFixed(1);

    // Area (~100 sq ft per kW)
    const area = Math.round(capacity * 100);

    // ─── Update On-Grid Card ───
    document.getElementById('ongridCapacity').textContent = capacity + ' kWp';
    document.getElementById('ongridCost').textContent = onGridCost.toLocaleString();
    document.getElementById('ongridSubsidy').textContent = subsidy.toLocaleString();
    document.getElementById('ongridNet').textContent = (onGridCost - subsidy).toLocaleString();
    document.getElementById('ongridSavings').textContent = yearlySavings.toLocaleString();
    document.getElementById('ongridPayback').textContent = onGridPayback;
    document.getElementById('ongridArea').textContent = area.toLocaleString();

    // ─── Update Off-Grid Card ───
    document.getElementById('offgridCapacity').textContent = capacity + ' kWp';
    document.getElementById('offgridCost').textContent = offGridCost.toLocaleString();
    document.getElementById('offgridNet').textContent = offGridCost.toLocaleString();
    document.getElementById('offgridSavings').textContent = yearlySavings.toLocaleString();
    document.getElementById('offgridPayback').textContent = offGridPayback;
    document.getElementById('offgridArea').textContent = area.toLocaleString();

    // ─── Update Hybrid Card ───
    document.getElementById('hybridCapacity').textContent = capacity + ' kWp';
    document.getElementById('hybridCost').textContent = hybridCost.toLocaleString();
    document.getElementById('hybridNet').textContent = hybridCost.toLocaleString();
    document.getElementById('hybridSavings').textContent = yearlySavings.toLocaleString();
    document.getElementById('hybridPayback').textContent = hybridPayback;
    document.getElementById('hybridArea').textContent = area.toLocaleString();
  }

  // ─── Aarna AI Public Recommendation ───
  async function getAarnaAIRec() {
    const btn = document.getElementById('aarnaAiBtn');
    btn.innerHTML = '<span class="animate-spin inline-block">⟳</span> Asking Aarna AI...';
    btn.disabled = true;

    const grid = document.getElementById('aiGridStatus').value;
    const backup = document.getElementById('aiBackupNeed').value;
    const bill = parseFloat(document.getElementById('monthlyBill').value) || 3000;

    try {
      const res = await fetch('/api/ai/recommend-system', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          gridStatus: grid,
          backupNeed: backup,
          monthlyBill: bill,
          location: document.getElementById('calcLocation').value || 'Madhya Pradesh',
          installationType: 'Residential'
        })
      });

      const data = await res.json();
      if (data.success && data.recommendation) {
        const rec = data.recommendation;
        document.getElementById('aarnaAiRecText').textContent = rec.recommendedSystem + ' Solar';
        document.getElementById('aarnaAiRecReason').textContent = rec.reasoning;

        const tags = document.getElementById('aarnaAiTags');
        tags.innerHTML = '';
        if (rec.benefits) {
          rec.benefits.forEach(b => {
            tags.innerHTML += `<span class="bg-white/20 px-3 py-1 rounded-full text-xs">${b}</span>`;
          });
        }
        if (rec.confidence) {
          tags.innerHTML += `<span class="bg-solar-orange px-3 py-1 rounded-full text-xs font-bold">Confidence: ${rec.confidence}</span>`;
        }
        document.getElementById('aarnaAiResult').classList.remove('hidden');
      } else {
        // Fallback to rule-based
        showRuleBasedRec(grid, backup);
      }
    } catch (err) {
      console.error('[AI] Error:', err);
      showRuleBasedRec(grid, backup);
    } finally {
      btn.innerHTML = '<span>✨</span> Get Aarna AI Recommendation';
      btn.disabled = false;
    }
  }

  function showRuleBasedRec(grid, backup) {
    let rec = 'On-Grid Solar';
    let reason = 'Reliable grid with no backup need = lowest cost, net metering benefit.';
    if (grid === 'nogrid') {
      rec = 'Off-Grid Solar';
      reason = 'No grid connection requires full battery backup & standalone system.';
    } else if (backup === 'yes') {
      rec = 'Hybrid Solar';
      reason = 'Battery backup needed for power during outages and night time.';
    }
    document.getElementById('aarnaAiRecText').textContent = rec;
    document.getElementById('aarnaAiRecReason').textContent = reason;
    document.getElementById('aarnaAiTags').innerHTML = '<span class="bg-white/20 px-3 py-1 rounded-full text-xs">Rule-based fallback</span>';
    document.getElementById('aarnaAiResult').classList.remove('hidden');
  }

  // Init
  document.addEventListener('DOMContentLoaded', calculateSolar);
</script>

