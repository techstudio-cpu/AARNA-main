          </div>

          <div class="mt-4 flex flex-wrap gap-2">
            <span class="bg-orange-100 text-orange-700 px-2 py-1 rounded-lg text-xs font-semibold">24×7 Power</span>
            <span class="bg-purple-100 text-purple-700 px-2 py-1 rounded-lg text-xs font-semibold">No Grid Needed</span>
            <span class="bg-red-100 text-red-700 px-2 py-1 rounded-lg text-xs font-semibold">Higher Cost</span>
          </div>
        </div>
        <a href="/contact?type=offgrid" class="block bg-solar-orange text-white text-center py-3 font-semibold hover:bg-orange-600 transition">Get Off-Grid Quote →</a>
      </div>

      <!-- Hybrid -->
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden border-t-4 border-tata-blue">
        <div class="p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-tata-blue/10 rounded-full flex items-center justify-center text-tata-blue text-lg">⚡</div>
            <div>
              <h3 class="text-lg font-bold text-gray-800">Hybrid Solar</h3>
