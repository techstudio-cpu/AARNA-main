<!-- Header -->
<header class="header">
  <div class="header-left">
    <button class="mobile-menu-toggle" onclick="toggleSidebar()" id="mobileMenuToggle">
      ☰
    </button>
    <h1><%= title || 'Dashboard' %></h1>
  </div>
  
  <div class="header-center">
    <input type="text" class="search-bar" id="globalSearch" placeholder="Search..." oninput="globalSearch()">
  </div>
  
  <div class="header-right">
    <button class="icon-btn" onclick="refreshData()" title="Refresh">
      🔄
    </button>
    <button class="icon-btn" onclick="exportData()" title="Export">
      📥
    </button>
    <div class="avatar"><%= (adminUser || 'A').charAt(0).toUpperCase() %></div>
  </div>
</header>

<script>
function toggleSidebar() {
  const sidebar = document.querySelector('.sidebar');
  if (sidebar) {
    sidebar.classList.toggle('sidebar--open');
  }
}
</script>
