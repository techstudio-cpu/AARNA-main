<%- include('partials/header') %>

<!-- Hero Section -->
<section class="relative min-h-[220px] sm:min-h-[280px] py-16 sm:py-28 overflow-hidden">
  <img src="https://images.unsplash.com/photo-1509391366360-2e959784a276?w=1600&q=80" alt="Solar panels on rooftop" class="absolute inset-0 w-full h-full object-cover object-center">
  <div class="absolute inset-0 bg-gradient-to-br from-solar-green/85 to-teal-800/85"></div>
  <div class="relative container mx-auto px-4 text-center text-white">
    <h1 class="text-2xl sm:text-4xl md:text-5xl font-bold mb-3 sm:mb-4">Solar <span class="text-solar-orange">Installation Types</span></h1>
    <p class="text-sm sm:text-xl text-gray-200 max-w-2xl mx-auto">Choose the right solar system for your home or business — On-Grid, Off-Grid, or Hybrid</p>
  </div>
</section>

<!-- Introduction -->
<section class="py-10 sm:py-16 bg-white">
  <div class="container mx-auto px-4 text-center max-w-3xl">
    <h2 class="text-xl sm:text-3xl font-bold text-gray-800 mb-4">Which Solar System is Right for You?</h2>
    <p class="text-gray-600 text-sm sm:text-base leading-relaxed">
      Not all solar installations are the same. Depending on your location, grid availability, and backup needs, 
      Aarna Solars recommends the perfect system using our AI-powered recommendation engine. Explore the three types below 
      and discover which one suits your energy requirements.
    </p>
  </div>
</section>

<!-- On-Grid Solar -->
<section class="py-12 sm:py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="bg-white rounded-2xl shadow-lg overflow-hidden mb-12">
      <div class="grid md:grid-cols-2">
        <div class="h-64 md:h-auto bg-cover bg-center" style="background-image: url('/on-grid.png')"></div>
        <div class="p-5 sm:p-8 md:p-12">
          <span class="bg-solar-green/10 text-solar-green px-4 py-1 rounded-full text-sm font-semibold">Most Popular</span>
          <h2 class="text-3xl font-bold text-gray-800 mt-4 mb-4">On-Grid Solar System</h2>
          <p class="text-gray-600 mb-6">
            On-Grid (Grid-Tied) solar systems are connected to the public electricity grid. They are the most cost-effective 
            solution for homes and businesses in areas with reliable power supply. Excess energy generated is fed back to 
            the grid through net metering, earning you credits on your electricity bill.
          </p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-solar-green rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>Lowest upfront cost — no batteries required</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-solar-green rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>Net metering — sell excess power to grid</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-solar-green rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>Govt. subsidy up to ₹78,000 for residential (PM Surya Ghar)</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-solar-green rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>3–5 year payback period</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-solar-green rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>Works only when grid is available — no backup during outage</span>
            </li>
          </ul>
          <div class="bg-orange-50 border-l-4 border-solar-orange p-4 rounded-lg">
            <p class="text-sm text-gray-700"><strong>Best for:</strong> Homes and businesses in cities/towns with reliable electricity grid who want to reduce electricity bills.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Off-Grid Solar -->
    <div class="bg-white rounded-2xl shadow-lg overflow-hidden mb-12">
      <div class="grid md:grid-cols-2">
        <div class="p-5 sm:p-8 md:p-12 order-2 md:order-1">
          <span class="bg-solar-orange/10 text-solar-orange px-4 py-1 rounded-full text-sm font-semibold">Remote Areas</span>
          <h2 class="text-3xl font-bold text-gray-800 mt-4 mb-4">Off-Grid Solar System</h2>
          <p class="text-gray-600 mb-6">
            Off-Grid systems operate completely independently from the utility grid. They store solar energy in batteries 
            for use during the night or on cloudy days. Ideal for remote locations where grid connection is unavailable 
            or extremely unreliable.
          </p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-solar-orange rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>Complete energy independence — no grid needed</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-solar-orange rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>Battery backup for 24×7 power supply</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-solar-orange rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>Ideal for villages, farms, and remote locations</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-solar-orange rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>No electricity bills ever</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-solar-orange rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>Higher upfront cost due to battery bank</span>
            </li>
          </ul>
          <div class="bg-orange-50 border-l-4 border-solar-orange p-4 rounded-lg">
            <p class="text-sm text-gray-700"><strong>Best for:</strong> Remote homes, farms, and areas with no electricity grid or frequent long outages.</p>
          </div>
        </div>
        <div class="h-64 md:h-auto bg-cover bg-center order-1 md:order-2" style="background-image: url('/off-grid.png')"></div>
      </div>
    </div>

    <!-- Hybrid Solar -->
    <div class="bg-white rounded-2xl shadow-lg overflow-hidden mb-12">
      <div class="grid md:grid-cols-2">
        <div class="h-64 md:h-auto bg-cover bg-center" style="background-image: url('/hybrid.png')"></div>
        <div class="p-5 sm:p-8 md:p-12">
          <span class="bg-tata-blue/10 text-tata-blue px-4 py-1 rounded-full text-sm font-semibold">Best of Both</span>
          <h2 class="text-3xl font-bold text-gray-800 mt-4 mb-4">Hybrid Solar System</h2>
          <p class="text-gray-600 mb-6">
            Hybrid systems combine the benefits of On-Grid and Off-Grid. They are connected to the grid AND include 
            battery storage. You can export excess power to the grid AND have battery backup for power cuts. The smartest 
            choice for areas with unreliable grid supply.
          </p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-tata-blue rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>Grid connection + battery backup combined</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-tata-blue rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>Net metering benefits + outage protection</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-tata-blue rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>Stores solar energy for night use</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-tata-blue rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>Highest flexibility and energy security</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="w-6 h-6 bg-tata-blue rounded-full flex items-center justify-center text-white text-sm">✓</span>
              <span>Moderate cost — balanced investment</span>
            </li>
          </ul>
          <div class="bg-orange-50 border-l-4 border-solar-orange p-4 rounded-lg">
            <p class="text-sm text-gray-700"><strong>Best for:</strong> Homes and businesses in areas with frequent power cuts who want both savings AND backup.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Comparison Table -->
<section class="py-10 sm:py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-8 sm:mb-12">
      <h2 class="text-xl sm:text-3xl font-bold text-gray-800 mb-3 sm:mb-4">Quick <span class="text-solar-orange">Comparison</span></h2>
      <p class="text-gray-600 max-w-2xl mx-auto text-sm sm:text-base">See how the three systems compare at a glance</p>
    </div>
    
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-solar-green text-white">
            <th class="p-4 rounded-tl-xl text-sm font-semibold">Feature</th>
            <th class="p-4 text-sm font-semibold">On-Grid</th>
            <th class="p-4 text-sm font-semibold">Off-Grid</th>
            <th class="p-4 rounded-tr-xl text-sm font-semibold">Hybrid</th>
          </tr>
        </thead>
        <tbody class="text-sm text-gray-700">
          <tr class="bg-gray-50"><td class="p-4 font-semibold">Grid Connection</td><td class="p-4">Required</td><td class="p-4">Not needed</td><td class="p-4">Required</td></tr>
          <tr class="bg-white"><td class="p-4 font-semibold">Battery Storage</td><td class="p-4">No</td><td class="p-4">Yes (large)</td><td class="p-4">Yes (medium)</td></tr>
          <tr class="bg-gray-50"><td class="p-4 font-semibold">Net Metering</td><td class="p-4 text-solar-green font-bold">Yes</td><td class="p-4">No</td><td class="p-4 text-solar-green font-bold">Yes</td></tr>
          <tr class="bg-white"><td class="p-4 font-semibold">Power During Outage</td><td class="p-4 text-red-500">No</td><td class="p-4 text-solar-green font-bold">Yes</td><td class="p-4 text-solar-green font-bold">Yes</td></tr>
          <tr class="bg-gray-50"><td class="p-4 font-semibold">Govt. Subsidy</td><td class="p-4 text-solar-green font-bold">Up to ₹78,000</td><td class="p-4">Limited</td><td class="p-4">Limited</td></tr>
          <tr class="bg-white"><td class="p-4 font-semibold">Upfront Cost</td><td class="p-4 text-solar-green font-bold">Lowest</td><td class="p-4">Highest</td><td class="p-4">Moderate</td></tr>
          <tr class="bg-gray-50"><td class="p-4 font-semibold">Best For</td><td class="p-4">Cities & towns</td><td class="p-4">Remote areas</td><td class="p-4">Unreliable grid areas</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-12 sm:py-20 bg-gradient-to-r from-solar-green to-teal-700 text-white">
  <div class="container mx-auto px-4 text-center">
    <h2 class="text-xl sm:text-3xl font-bold mb-4">Not Sure Which One to Choose?</h2>
    <p class="text-gray-200 mb-6 sm:mb-8 max-w-xl mx-auto text-sm sm:text-base">
      Our AI-powered quotation tool analyzes your grid availability and backup needs to recommend the perfect system. 
      Get an instant customized proposal.
    </p>
    <a href="/solar-calculator" class="inline-block bg-solar-orange text-white px-8 py-3 sm:py-4 rounded-full font-semibold hover:bg-orange-600 transition shadow-lg text-sm sm:text-base">
      Try Aarna AI Calculator →
    </a>
  </div>
</section>

<%- include('partials/footer') %>
