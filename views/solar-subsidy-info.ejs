<%- include('partials/header') %>

<!-- Solar Subsidy Information Page -->
<section class="py-16 sm:py-24 bg-gradient-to-br from-solar-green to-teal-700">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center text-white">
      <p class="text-lg font-semibold mb-4">🏛️ Government Scheme</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold mb-6">
        PM Surya Ghar Muft Bijli Yojana
      </h1>
      <p class="text-xl sm:text-2xl mb-8 opacity-90">
        Complete guide to government solar subsidy for residential consumers
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/subsidy-calculator" class="bg-white text-solar-green px-8 py-4 rounded-full font-semibold hover:bg-gray-100 transition shadow-lg">
          Check Your Eligibility
        </a>
        <a href="/contact" class="border-2 border-white text-white px-8 py-4 rounded-full font-semibold hover:bg-white hover:text-solar-green transition">
          Apply for Subsidy
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Subsidy Overview -->
<section class="py-16 sm:py-24 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-800 mb-8 text-center">
        What is PM Surya Ghar Scheme?
      </h2>
      
      <div class="bg-gradient-to-r from-green-50 to-teal-50 rounded-2xl p-8 mb-8">
        <p class="text-gray-700 text-lg leading-relaxed">
          The <strong>PM Surya Ghar Muft Bijli Yojana</strong> is a Government of India initiative launched to promote solar energy adoption among residential consumers. Under this scheme, eligible households can receive financial subsidies to install rooftop solar systems, significantly reducing the upfront investment cost.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <div class="bg-solar-orange/10 rounded-2xl p-6 text-center">
          <div class="text-4xl mb-3">🏠</div>
          <h3 class="font-bold text-gray-800 mb-2">Residential Focus</h3>
          <p class="text-gray-600 text-sm">Exclusively for residential properties including houses, flats, and housing societies</p>
        </div>
        
        <div class="bg-solar-green/10 rounded-2xl p-6 text-center">
          <div class="text-4xl mb-3">💰</div>
          <h3 class="font-bold text-gray-800 mb-2">Financial Support</h3>
          <p class="text-gray-600 text-sm">Direct subsidy transfer to your bank account after successful installation</p>
        </div>
        
        <div class="bg-blue-500/10 rounded-2xl p-6 text-center">
          <div class="text-4xl mb-3">🇮🇳</div>
          <h3 class="font-bold text-gray-800 mb-2">National Coverage</h3>
          <p class="text-gray-600 text-sm">Available across all states and union territories of India</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Subsidy Amounts -->
<section class="py-16 sm:py-24 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-800 mb-8 text-center">
        Subsidy Amounts
      </h2>
      
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden mb-8">
        <table class="w-full">
          <thead>
            <tr class="bg-solar-orange text-white">
              <th class="px-6 py-4 text-left">System Capacity</th>
              <th class="px-6 py-4 text-left">Subsidy Amount</th>
              <th class="px-6 py-4 text-left">Net Cost (approx)</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b">
              <td class="px-6 py-4 font-semibold">Up to 2 kW</td>
              <td class="px-6 py-4 text-solar-orange font-bold">₹30,000 per kW</td>
              <td class="px-6 py-4">₹1.2L - ₹1.5L</td>
            </tr>
            <tr class="border-b">
              <td class="px-6 py-4 font-semibold">2 kW to 3 kW</td>
              <td class="px-6 py-4 text-solar-orange font-bold">₹78,000 (fixed)</td>
              <td class="px-6 py-4">₹1.8L - ₹2.2L</td>
            </tr>
            <tr class="border-b">
              <td class="px-6 py-4 font-semibold">Above 3 kW</td>
              <td class="px-6 py-4 text-solar-orange font-bold">₹78,000 (maximum)</td>
              <td class="px-6 py-4">₹2.5L - ₹3.0L+</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 rounded-r-xl">
        <p class="text-gray-700">
          <strong>💡 Note:</strong> For systems larger than 3 kW, the subsidy remains capped at ₹78,000. However, larger systems still offer higher savings due to increased electricity generation.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Eligibility Criteria -->
<section class="py-16 sm:py-24 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-800 mb-8 text-center">
        Eligibility Criteria
      </h2>
      
      <div class="space-y-4">
        <div class="flex items-start gap-4 bg-green-50 p-6 rounded-xl">
          <div class="w-10 h-10 bg-green-500 rounded-full flex items-center justify-center text-white flex-shrink-0">
            ✓
          </div>
          <div>
            <h3 class="font-bold text-gray-800 mb-1">Property Ownership</h3>
            <p class="text-gray-600">Must be the owner of the residential property. Rented properties are not eligible.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4 bg-green-50 p-6 rounded-xl">
          <div class="w-10 h-10 bg-green-500 rounded-full flex items-center justify-center text-white flex-shrink-0">
            ✓
          </div>
          <div>
            <h3 class="font-bold text-gray-800 mb-1">Domestic Electricity Connection</h3>
            <p class="text-gray-600">Should have a domestic electricity connection. Commercial connections are not eligible.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4 bg-green-50 p-6 rounded-xl">
          <div class="w-10 h-10 bg-green-500 rounded-full flex items-center justify-center text-white flex-shrink-0">
            ✓
          </div>
          <div>
            <h3 class="font-bold text-gray-800 mb-1">Valid Documentation</h3>
            <p class="text-gray-600">Must have valid property documents, Aadhar card, PAN card, and bank account.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4 bg-green-50 p-6 rounded-xl">
          <div class="w-10 h-10 bg-green-500 rounded-full flex items-center justify-center text-white flex-shrink-0">
            ✓
          </div>
          <div>
            <h3 class="font-bold text-gray-800 mb-1">Authorized Vendor</h3>
            <p class="text-gray-600">Installation must be done by a government-authorized vendor like Aarna Solars.</p>
          </div>
        </div>
        
        <div class="flex items-start gap-4 bg-red-50 p-6 rounded-xl">
          <div class="w-10 h-10 bg-red-500 rounded-full flex items-center justify-center text-white flex-shrink-0">
            ✗
          </div>
          <div>
            <h3 class="font-bold text-gray-800 mb-1">Not Eligible</h3>
            <p class="text-gray-600">Commercial properties, rented homes, and institutional buildings (schools, hospitals) are not covered under this residential scheme.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Application Process -->
<section class="py-16 sm:py-24 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-800 mb-8 text-center">
        Application Process
      </h2>
      
      <div class="space-y-6">
        <div class="bg-white rounded-2xl shadow-lg p-6 flex items-start gap-4">
          <div class="w-12 h-12 bg-solar-orange rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">
            1
          </div>
          <div>
            <h3 class="font-bold text-gray-800 mb-2">Free Solar Assessment</h3>
            <p class="text-gray-600">Contact Aarna Solars for a free site assessment and system design recommendation.</p>
          </div>
        </div>
        
        <div class="bg-white rounded-2xl shadow-lg p-6 flex items-start gap-4">
          <div class="w-12 h-12 bg-solar-orange rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">
            2
          </div>
          <div>
            <h3 class="font-bold text-gray-800 mb-2">Submit Application</h3>
            <p class="text-gray-600">Submit subsidy application through the official government portal with required documents.</p>
          </div>
        </div>
        
        <div class="bg-white rounded-2xl shadow-lg p-6 flex items-start gap-4">
          <div class="w-12 h-12 bg-solar-orange rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">
            3
          </div>
          <div>
            <h3 class="font-bold text-gray-800 mb-2">System Installation</h3>
            <p class="text-gray-600">Our team installs the solar system using approved components and certified practices.</p>
          </div>
        </div>
        
        <div class="bg-white rounded-2xl shadow-lg p-6 flex items-start gap-4">
          <div class="w-12 h-12 bg-solar-orange rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">
            4
          </div>
          <div>
            <h3 class="font-bold text-gray-800 mb-2">Inspection & Approval</h3>
            <p class="text-gray-600">Government officials inspect the installation and approve subsidy disbursement.</p>
          </div>
        </div>
        
        <div class="bg-white rounded-2xl shadow-lg p-6 flex items-start gap-4">
          <div class="w-12 h-12 bg-solar-orange rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">
            5
          </div>
          <div>
            <h3 class="font-bold text-gray-800 mb-2">Subsidy Transfer</h3>
            <p class="text-gray-600">Approved subsidy amount is directly transferred to your registered bank account.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Required Documents -->
<section class="py-16 sm:py-24 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-800 mb-8 text-center">
