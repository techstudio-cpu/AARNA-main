          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="text-solar-orange mt-1">•</span>
              <span class="text-gray-600">Aadhar Card (mandatory)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-solar-orange mt-1">•</span>
              <span class="text-gray-600">PAN Card</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-solar-orange mt-1">•</span>
              <span class="text-gray-600">Property Ownership Documents</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-solar-orange mt-1">•</span>
              <span class="text-gray-600">Bank Account Details</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-solar-orange mt-1">•</span>
              <span class="text-gray-600">Latest Electricity Bill</span>
            </li>
          </ul>
        </div>
        
        <div class="bg-gray-50 rounded-xl p-6">
          <h3 class="font-bold text-gray-800 mb-4">Supporting Documents</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="text-solar-green mt-1">•</span>
              <span class="text-gray-600">Passport Size Photos</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-solar-green mt-1">•</span>
              <span class="text-gray-600">Address Proof (if different from Aadhar)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-solar-green mt-1">•</span>
              <span class="text-gray-600">Bank Passbook (cancelled cheque)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-solar-green mt-1">•</span>
              <span class="text-gray-600">System Installation Certificate</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-solar-green mt-1">•</span>
              <span class="text-gray-600">Vendor Authorization Letter</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="py-16 sm:py-24 bg-gradient-to-r from-solar-orange to-orange-500">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center text-white">
      <h2 class="text-3xl sm:text-4xl font-bold mb-6">
