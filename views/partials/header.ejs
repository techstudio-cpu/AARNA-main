  <style>
    body { font-family: 'Poppins', sans-serif; }
    .gradient-text {
      background: linear-gradient(to right, #E87722, #1B5E20);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    /* Enhanced Responsiveness */

    /* Tablet: reduce section padding, refine text */
    @media (max-width: 1023px) {
      section { padding-top: 3.5rem; padding-bottom: 3.5rem; }
    }

    /* Large phone / small tablet */
    @media (max-width: 767px) {
      .container { padding-left: 1rem; padding-right: 1rem; }
      nav .container { padding-left: 0.75rem; padding-right: 0.75rem; }

      section { padding-top: 2.5rem; padding-bottom: 2.5rem; }

      h1 { font-size: 1.75rem !important; line-height: 1.2 !important; }
      h2 { font-size: 1.5rem !important; }
      h3 { font-size: 1.15rem !important; }

      /* Better touch targets */
      a, button { min-height: 44px; }

      /* Fix grid layouts */
      .grid { gap: 1rem; }

      /* Prevent iOS zoom on inputs */
      input, select, textarea { font-size: 16px !important; }

      /* Responsive tables */
      .overflow-x-auto { -webkit-overflow-scrolling: touch; }
      table { min-width: 600px; }
    }

    /* Phone */
    @media (max-width: 479px) {
      .container { padding-left: 0.75rem; padding-right: 0.75rem; }

      section { padding-top: 2rem; padding-bottom: 2rem; }

      h1 { font-size: 1.4rem !important; line-height: 1.2 !important; }
      h2 { font-size: 1.2rem !important; }
      h3 { font-size: 1.05rem !important; }

      .flex-wrap { gap: 0.5rem; }

      /* Compact cards and form elements */
      .rounded-2xl { border-radius: 1rem; }
    }
    
    /* Smooth scrolling */
    html { scroll-behavior: smooth; }
    
    /* Better focus states for accessibility */
    a:focus, button:focus, input:focus, select:focus, textarea:focus {
      outline: 2px solid #E87722;
      outline-offset: 2px;
    }
    
    /* Prevent horizontal scroll */
    body { overflow-x: hidden; }
    
    /* Safe area insets for notched devices */
    @supports (padding: max(0px)) {
      body {
        padding-left: max(0px, env(safe-area-inset-left));
        padding-right: max(0px, env(safe-area-inset-right));
      }
    }
  </style>
  
